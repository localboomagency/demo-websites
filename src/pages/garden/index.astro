    <!-- 4. SERVICES -->
    <section id="services" class="services">
      <div class="container">
        <p class="section-eyebrow">What We Do</p>
        <h2>Our Garden Services</h2>
        <p class="section-sub">Whether you need a tidy-up or a complete overhaul, our experienced team handles every aspect of your outdoor space.</p>
        <div class="services-grid">

          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="10" width="15" height="7" rx="2"/>
                <circle cx="5.5" cy="19" r="2"/>
                <circle cx="13.5" cy="19" r="2"/>
                <path d="M17 13h2l2-5h-5"/>
                <path d="M9 10V7"/>
              </svg>
            </div>
            <h3>Lawn Care &amp; Mowing</h3>
            <p>Regular cuts, edging, scarifying and feeding to keep your lawn lush and green through every season.</p>
          </div>

          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="6" cy="6" r="3"/>
                <circle cx="6" cy="18" r="3"/>
                <line x1="20" y1="4" x2="8.12" y2="15.88"/>
                <line x1="14.47" y1="14.48" x2="20" y2="20"/>
                <line x1="8.12" y1="8.12" x2="12" y2="12"/>
              </svg>
            </div>
            <h3>Hedge Trimming &amp; Shaping</h3>
            <p>Precise cutting and shaping of hedges, topiaries and boundary shrubs for a crisp, well-defined finish.</p>
          </div>

          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 6 5 6 21 6"/>
                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6m3 0V4h6v2"/>
                <line x1="10" y1="11" x2="10" y2="17"/>
                <line x1="14" y1="11" x2="14" y2="17"/>
              </svg>
            </div>
            <h3>Garden Clearance</h3>
            <p>Full removal of overgrowth, weeds, waste and unwanted materials. We leave your space clean and ready for use.</p>
          </div>

          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22V12"/>
                <path d="M12 12C10 12 4 10 4 4c2 0 8 2 8 8z"/>
                <path d="M12 12c2 0 8-2 8-8-2 0-8 2-8 8z"/>
              </svg>
            </div>
            <h3>Planting &amp; Landscaping</h3>
            <p>Seasonal planting schemes, border redesigns and soft landscaping to bring colour and structure to your garden.</p>
          </div>

          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2C12 2 5 10 5 14a7 7 0 0 0 14 0c0-4-7-12-7-12z"/>
              </svg>
            </div>
            <h3>Patio &amp; Path Cleaning</h3>
            <p>Professional pressure washing of patios, driveways and paths to remove moss, algae and built-up grime.</p>
          </div>

          <div class="service-card">
            <div class="service-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2l-8 11h5l-4 9h14l-4-9h5z"/>
                <line x1="12" y1="19" x2="12" y2="22"/>
              </svg>
            </div>
            <h3>Tree &amp; Shrub Care</h3>
            <p>Crown lifting, deadwood removal, formative pruning and stump grinding carried out safely by trained arborists.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- 5. REVIEWS -->
    <section id="reviews" class="reviews">
