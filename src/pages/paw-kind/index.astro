---
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Paw Kind | Dog Walking &amp; Daycare in Bovey Tracey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Nunito', system-ui, sans-serif;
      color: #2C1A0E;
      background: #FAF5EE;
      line-height: 1.6;
    }
    a { text-decoration: none; color: inherit; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

    /* ─── NAV ─── */
    nav {
      background: #FAF5EE;
      border-bottom: 1px solid #E8D9C8;
      position: sticky;
      top: 0;
      z-index: 200;
    }

    .nav-inner {
      display: flex;
      align-items: center;
      gap: 2rem;
      height: 68px;
    }

    .nav-logo {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      flex-shrink: 0;
      font-size: 1.35rem;
      font-weight: 900;
      color: #2C1A0E;
    }

    .nav-logo-paw {
      width: 30px;
      height: 30px;
      color: #C0563A;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      flex: 1;
      justify-content: center;
    }

    .nav-socials {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      flex-shrink: 0;
    }

    .nav-social-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      border-radius: 7px;
      color: #9E7B65;
      border: 1.5px solid #E8D9C8;
      transition: color 0.2s, border-color 0.2s, background 0.2s;
    }

    .nav-social-icon:hover {
      color: #C0563A;
      border-color: #C0563A;
      background: rgba(192,86,58,0.06);
    }

    .nav-links a {
      font-size: 0.9rem;
      font-weight: 700;
      color: #6B4C3B;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: #C0563A; }

    .nav-phone {
      background: #C0563A;
      color: #fff;
      padding: 0.7rem 1.4rem;
      border-radius: 8px;
      font-weight: 800;
      font-size: 0.88rem;
      white-space: nowrap;
      flex-shrink: 0;
      transition: background 0.2s, transform 0.15s;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }

    .nav-phone:hover { background: #A84830; transform: translateY(-1px); }

    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: 1.5px solid #E8D9C8;
      border-radius: 6px;
      padding: 0.5rem 0.6rem;
      cursor: pointer;
      flex-shrink: 0;
    }

    .nav-hamburger span {
      display: block;
      width: 20px;
      height: 2px;
      background: #6B4C3B;
      border-radius: 2px;
    }

    /* ─── HERO ─── */
    .hero {
      position: relative;
      background: linear-gradient(145deg, #FAF5EE 0%, #F2E5D4 60%, #EDD9C4 100%);
      overflow: hidden;
      padding: 4.5rem 0 5rem;
    }

    /* Decorative paw prints */
    .paw-deco {
      position: absolute;
      fill: #C89A2E;
      pointer-events: none;
    }
    .paw-deco-1 { width: 170px; top: -25px; right: 6%; transform: rotate(22deg); opacity: 0.13; }
    .paw-deco-2 { width: 85px; top: 28%; right: 15%; transform: rotate(-12deg); opacity: 0.11; }
    .paw-deco-3 { width: 55px; top: 55%; right: 9%; transform: rotate(8deg); opacity: 0.09; }
    .paw-deco-4 { width: 210px; bottom: -50px; left: -35px; transform: rotate(-28deg); opacity: 0.1; }
    .paw-deco-5 { width: 60px; bottom: 30%; left: 8%; transform: rotate(15deg); opacity: 0.12; }
    .paw-deco-6 { width: 40px; top: 12%; left: 5%; transform: rotate(-8deg); opacity: 0.09; }

    .hero-content {
      position: relative;
      z-index: 1;
      max-width: 680px;
      margin: 0 auto;
      text-align: center;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: rgba(192,86,58,0.1);
      color: #C0563A;
      font-size: 0.74rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.35rem 1rem;
      border-radius: 100px;
      border: 1px solid rgba(192,86,58,0.25);
      margin-bottom: 0.85rem;
    }

    /* PLACEHOLDER: replace with real Google review data */
    .review-widget {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: #fff;
      border: 1px solid #E8D9C8;
      border-radius: 10px;
      padding: 0.55rem 1.1rem;
      margin-bottom: 1.1rem;
      box-shadow: 0 2px 8px rgba(44,26,14,0.07);
    }

    .review-stars { color: #FBBC04; font-size: 0.88rem; letter-spacing: -0.5px; }
    .review-text { font-size: 0.8rem; color: #6B4C3B; font-weight: 700; }

    .hero h1 {
      font-size: clamp(2rem, 4.8vw, 3.25rem);
      font-weight: 900;
      color: #2C1A0E;
      line-height: 1.1;
      margin-bottom: 0.8rem;
    }

    .hero h1 .accent { color: #C0563A; }

    .hero-sub {
      font-size: 1rem;
      color: #6B4C3B;
      line-height: 1.65;
      margin-bottom: 1.1rem;
      max-width: 520px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-bullets {
      list-style: none;
      margin-bottom: 1.4rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem 2rem;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
      text-align: left;
    }

    .hero-bullets li {
      font-size: 0.9rem;
      color: #4B2E1A;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .bullet-paw {
      width: 16px;
      height: 16px;
      min-width: 16px;
      color: #C89A2E;
      flex-shrink: 0;
    }

    .hero-ctas {
      display: flex;
      justify-content: center;
      gap: 0.85rem;
      flex-wrap: wrap;
    }

    .btn-primary {
      background: #C0563A;
      color: #fff;
      padding: 0.9rem 1.8rem;
      border-radius: 8px;
      font-weight: 800;
      font-size: 0.93rem;
      transition: background 0.2s, transform 0.15s;
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
    }

    .btn-primary:hover { background: #A84830; transform: translateY(-1px); }

    .btn-secondary {
      background: #fff;
      color: #C0563A;
      padding: 0.9rem 1.8rem;
      border-radius: 8px;
      font-weight: 800;
      font-size: 0.93rem;
      border: 2px solid #C0563A;
      transition: background 0.2s, color 0.2s, transform 0.15s;
      display: inline-block;
    }

    .btn-secondary:hover { background: #C0563A; color: #fff; transform: translateY(-1px); }

    /* ─── TRUST BAR ─── */
    .trust-bar {
      background: #2C1A0E;
      padding: 2rem 0;
    }

    .trust-bar-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      text-align: center;
    }

    .trust-item {
      padding: 0.75rem 1rem;
      border-right: 1px solid rgba(255,255,255,0.08);
    }

    .trust-item:last-child { border-right: none; }

    .trust-number {
      font-size: 1.7rem;
      font-weight: 900;
      color: #C89A2E;
      line-height: 1;
      margin-bottom: 0.3rem;
    }

    .trust-label {
      font-size: 0.72rem;
      color: rgba(255,255,255,0.5);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    /* ─── SERVICES ─── */
    .services {
      background: #FAF5EE;
      padding: 5rem 0;
    }

    .section-eyebrow {
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #C0563A;
      margin-bottom: 0.5rem;
    }

    .section-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .section-header h2 {
      font-size: clamp(1.5rem, 3vw, 2.1rem);
      font-weight: 900;
      color: #2C1A0E;
      margin-bottom: 0.55rem;
    }

    .section-header p {
      color: #6B4C3B;
      font-size: 0.95rem;
      max-width: 500px;
      margin: 0 auto;
      line-height: 1.65;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    .service-card {
      background: #fff;
      border: 1px solid #E8D9C8;
      border-radius: 14px;
      padding: 1.9rem;
      transition: box-shadow 0.2s, transform 0.2s;
    }

    .service-card:hover {
      box-shadow: 0 6px 24px rgba(44,26,14,0.09);
      transform: translateY(-2px);
    }

    .service-icon {
      width: 46px;
      height: 46px;
      background: rgba(200,154,46,0.12);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      color: #C89A2E;
    }

    .service-card h3 {
      font-size: 1.05rem;
      font-weight: 800;
      color: #2C1A0E;
      margin-bottom: 0.45rem;
    }

    .service-card p {
      font-size: 0.87rem;
      color: #6B4C3B;
      line-height: 1.65;
    }

    /* ─── REVIEWS ─── */
    .reviews {
      background: #F0E6D8;
      padding: 5rem 0;
    }

    .reviews-meta {
      text-align: center;
      margin-bottom: 2.75rem;
    }

    .reviews-score {
      font-size: 3.5rem;
      font-weight: 900;
      color: #2C1A0E;
      line-height: 1;
    }

    .reviews-stars-big {
      color: #FBBC04;
      font-size: 1.35rem;
      margin: 0.3rem 0;
    }

    .reviews-count {
      font-size: 0.86rem;
      color: #6B4C3B;
      font-weight: 700;
      margin-bottom: 1.1rem;
    }

    .reviews-meta h2 {
      font-size: clamp(1.4rem, 2.5vw, 2rem);
      font-weight: 900;
      color: #2C1A0E;
    }

    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    .review-card {
      background: #fff;
      border: 1px solid #E8D9C8;
      border-radius: 14px;
      padding: 1.75rem;
    }

    .review-card-stars {
      color: #FBBC04;
      font-size: 0.9rem;
      margin-bottom: 0.85rem;
    }

    .review-quote {
      font-size: 0.9rem;
      color: #4B2E1A;
      line-height: 1.65;
      margin-bottom: 1.1rem;
      font-style: italic;
    }

    .review-author { font-size: 0.88rem; font-weight: 800; color: #2C1A0E; }
    .review-location { font-size: 0.78rem; color: #9E7B65; margin-top: 0.15rem; }

    /* ─── ABOUT ─── */
    .about {
      background: #FAF5EE;
      padding: 5rem 0;
      position: relative;
      overflow: hidden;
    }

    .about-paw-bg {
      position: absolute;
      right: -80px;
      top: 50%;
      transform: translateY(-50%) rotate(15deg);
      width: 340px;
      fill: #C89A2E;
      opacity: 0.055;
      pointer-events: none;
    }

    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
      position: relative;
      z-index: 1;
    }

    .about-image-placeholder {
      background: #F0E6D8;
      border: 2px dashed #D4B89A;
      border-radius: 16px;
      height: 400px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 1rem;
      color: #9E7B65;
    }

    .about-image-placeholder svg { width: 60px; height: 60px; opacity: 0.35; }
    .about-image-placeholder p { font-size: 0.82rem; font-weight: 700; }

    .about-content h2 {
      font-size: clamp(1.4rem, 2.5vw, 2rem);
      font-weight: 900;
      color: #2C1A0E;
      line-height: 1.2;
      margin-bottom: 1.2rem;
    }

    .about-content > p {
      font-size: 0.93rem;
      color: #6B4C3B;
      line-height: 1.75;
      margin-bottom: 1rem;
    }

    .about-highlights {
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      margin-top: 1.5rem;
    }

    .about-highlight {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .about-highlight-icon {
      width: 20px;
      height: 20px;
      min-width: 20px;
      color: #C0563A;
      margin-top: 0.1rem;
    }

    .about-highlight-text {
      font-size: 0.9rem;
      color: #4B2E1A;
      font-weight: 700;
      line-height: 1.45;
    }

    /* ─── CONTACT ─── */
    .contact {
      background: #F0E6D8;
      padding: 5rem 0;
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 4rem;
      align-items: start;
    }

    .contact-info h2 {
      font-size: clamp(1.4rem, 2.5vw, 2rem);
      font-weight: 900;
      color: #2C1A0E;
      line-height: 1.2;
      margin-bottom: 0.8rem;
    }

    .contact-info > p {
      font-size: 0.93rem;
      color: #6B4C3B;
      line-height: 1.65;
      margin-bottom: 2rem;
    }

    .contact-detail { margin-bottom: 1.2rem; }

    .contact-detail-label {
      font-size: 0.68rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.09em;
      color: #9E7B65;
      margin-bottom: 0.2rem;
    }

    .contact-detail-value {
      font-size: 0.93rem;
      color: #2C1A0E;
      font-weight: 700;
      line-height: 1.5;
    }

    .contact-detail-value a { color: #2C1A0E; }
    .contact-detail-value a:hover { color: #C0563A; text-decoration: underline; }

    .contact-form {
      background: #fff;
      border-radius: 16px;
      padding: 2.5rem;
      box-shadow: 0 4px 20px rgba(44,26,14,0.08);
    }

    .contact-form h3 {
      font-size: 1.1rem;
      font-weight: 900;
      color: #2C1A0E;
      margin-bottom: 1.5rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .form-group { margin-bottom: 1.2rem; }

    .form-group label {
      display: block;
      font-size: 0.72rem;
      font-weight: 800;
      color: #6B4C3B;
      margin-bottom: 0.4rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .form-group input,
    .form-group textarea,
    .form-group select {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1.5px solid #E8D9C8;
      border-radius: 8px;
      font-family: inherit;
      font-size: 0.93rem;
      color: #2C1A0E;
      background: #FAF5EE;
      transition: border-color 0.2s;
      outline: none;
      appearance: none;
    }

    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus { border-color: #C0563A; }

    .form-group textarea { resize: vertical; min-height: 100px; }

    .form-submit {
      width: 100%;
      background: #C0563A;
      color: #fff;
      border: none;
      padding: 0.95rem;
      border-radius: 8px;
      font-family: inherit;
      font-size: 0.97rem;
      font-weight: 800;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s;
    }

    .form-submit:hover { background: #A84830; transform: translateY(-1px); }

    /* ─── FOOTER ─── */
    footer {
      background: #2C1A0E;
      color: #9E7B65;
      padding: 3.5rem 0 2rem;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: 3rem;
      margin-bottom: 2.5rem;
    }

    .footer-logo {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1.15rem;
      font-weight: 900;
      color: #FAF5EE;
      margin-bottom: 0.65rem;
    }

    .footer-logo svg { color: #C89A2E; }

    .footer-brand-desc {
      font-size: 0.83rem;
      line-height: 1.65;
      color: #6B4C3B;
      margin-bottom: 1.3rem;
    }

    .footer-social { display: flex; gap: 0.6rem; }

    .footer-social-item {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: rgba(255,255,255,0.07);
      color: #9E7B65;
      transition: background 0.2s, color 0.2s;
    }

    .footer-social-item:hover { background: rgba(255,255,255,0.13); color: #FAF5EE; }

    .footer-col-title {
      font-size: 0.7rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #FAF5EE;
      margin-bottom: 1.1rem;
    }

    .footer-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
    }

    .footer-list li { font-size: 0.83rem; color: #6B4C3B; line-height: 1.5; }

    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,0.07);
      padding-top: 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .footer-copy { font-size: 0.78rem; color: #4B2E1A; }

    /* ─── WHATSAPP ─── */
    .whatsapp-btn {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 9999;
      background: #25D366;
      color: #fff;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.2rem;
      border-radius: 50px;
      font-family: 'Nunito', system-ui, sans-serif;
      font-weight: 800;
      font-size: 0.88rem;
      box-shadow: 0 4px 16px rgba(37,211,102,0.35);
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .whatsapp-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(37,211,102,0.45);
    }

    .whatsapp-label { display: inline; }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 860px) {
      .hero-bullets { grid-template-columns: 1fr; max-width: 340px; }
      .services-grid { grid-template-columns: repeat(2, 1fr); }
      .reviews-grid { grid-template-columns: repeat(2, 1fr); }
      .about-grid { grid-template-columns: 1fr; }
      .contact-grid { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .trust-bar-grid { grid-template-columns: repeat(2, 1fr); }
      .trust-item { border-right: none; }
    }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-socials { display: none; }
      .nav-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: auto;
        padding: 0.75rem 0;
        gap: 0.5rem;
      }
      .nav-hamburger { display: flex; }

      .hero {
        padding: 2rem 0 2.5rem;
      }
      .hero-content { text-align: center; }
      .hero-badge { margin-bottom: 0.7rem; }
      .review-widget { margin-bottom: 0.85rem; }
      .hero h1 { font-size: clamp(2.65rem, 10.5vw, 3.9rem); margin-bottom: 0.6rem; }
      .hero-sub { font-size: 0.9rem; margin-bottom: 0.9rem; }
      .hero-bullets { margin-bottom: 1.1rem; max-width: 100%; margin-left: 0; margin-right: 0; gap: 0.4rem; }
      .hero-ctas { gap: 0.6rem; }
      .btn-primary, .btn-secondary { padding: 0.75rem 1.4rem; font-size: 0.88rem; }
      .paw-deco-4, .paw-deco-6 { display: none; }

      .form-row { grid-template-columns: 1fr; }
    }

    @media (max-width: 580px) {
      .services-grid { grid-template-columns: 1fr; }
      .reviews-grid { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
    }

    @media (max-width: 480px) {
      .whatsapp-label { display: none; }
      .whatsapp-btn {
        padding: 0;
        width: 52px;
        height: 52px;
        border-radius: 50%;
        justify-content: center;
      }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="container">
    <div class="nav-inner">
      <a href="#" class="nav-logo" aria-label="Paw Kind home">
        <!-- Paw logo -->
