---
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jamie Fearn Hypnotherapy | Hypnotherapy &amp; Coaching in Bovey Tracey</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    :root {
      --bg:         #F7F4F0;
      --bg-card:    #EDE6F5;
      --bg-mid:     #F0EBF8;
      --bg-dark:    #221535;
      --text:       #1E1529;
      --mid:        #5E4B7A;
      --light:      #8B75A8;
      --border:     #D8CFE8;
      --accent:     #7045B2;
      --accent-mid: #56369A;
      --cream:      #FAF7F4;
      --gold:       #C49A20;
    }

    body { font-family: 'Inter', system-ui, sans-serif; color: var(--text); background: var(--bg); line-height: 1.6; }
    a { text-decoration: none; color: inherit; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

    /* ─── HEADER ─── */
    header {
      background: var(--cream);
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 200;
    }
    .nav-inner {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      height: 68px;
      gap: 1rem;
    }
    .nav-logo { display: flex; align-items: center; gap: 0.6rem; flex-shrink: 0; }
    .nav-logo-name {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--text);
      line-height: 1.2;
    }
    .nav-logo-name small {
      display: block;
      font-family: 'Inter', sans-serif;
      font-size: 0.58rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--light);
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      justify-content: center;
    }
    .nav-links a { font-size: 0.85rem; font-weight: 500; color: var(--mid); letter-spacing: 0.02em; transition: color 0.2s; }
    .nav-links a:hover { color: var(--text); }

    .nav-right { display: flex; align-items: center; gap: 0.6rem; flex-shrink: 0; }

    .btn-nav-phone {
      display: flex; align-items: center; gap: 0.4rem;
      font-size: 0.85rem; font-weight: 500; color: var(--mid);
      transition: color 0.2s; white-space: nowrap;
    }
    .btn-nav-phone:hover { color: var(--accent); }

    .btn-nav-book {
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.65rem 1.25rem;
      background: var(--accent); color: #fff;
      border-radius: 50px;
      font-size: 0.85rem; font-weight: 600; letter-spacing: 0.02em;
      transition: all 0.2s; white-space: nowrap;
    }
    .btn-nav-book:hover { background: var(--accent-mid); transform: translateY(-1px); }

    .nav-hamburger {
      display: none;
      align-items: center; justify-content: center;
      width: 40px; height: 40px;
      background: transparent; border: 1.5px solid var(--border);
      border-radius: 8px; cursor: pointer; color: var(--text);
    }

    @media (max-width: 768px) {
      .nav-inner { grid-template-columns: 1fr auto auto; gap: 0.6rem; }
      .nav-links, .btn-nav-phone { display: none; }
      .btn-nav-book { display: inline-flex; padding: 0.55rem 1rem; font-size: 0.78rem; }
      .nav-hamburger { display: flex; }
      .nav-right { justify-self: auto; }
    }

    /* ─── HERO ─── */
    .hero {
      background: var(--cream);
      padding: 3.5rem 0 0;
      overflow: hidden;
    }
    .hero-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
    }
    .hero-content { padding-bottom: 3.5rem; }

    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-size: 0.7rem; font-weight: 600;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--accent);
      padding: 0.28rem 0.85rem;
      background: var(--bg-card);
      border: 1px solid var(--border); border-radius: 50px;
      margin-bottom: 1rem;
    }
    .hero-eyebrow-dot { width: 5px; height: 5px; background: var(--accent); border-radius: 50%; }

    .hero h1 {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: clamp(2.2rem, 4.5vw, 3.2rem);
      font-weight: 600;
      line-height: 1.15;
      color: var(--text);
      margin-bottom: 0.9rem;
    }
    .hero h1 em { font-style: italic; font-weight: 400; color: var(--accent); }

    .hero-sub {
      font-size: clamp(0.9rem, 1.6vw, 1rem);
      color: var(--mid); font-weight: 300; line-height: 1.75;
      max-width: 460px;
      margin-bottom: 1.2rem;
    }

    /* Google review widget */
    /* PLACEHOLDER: replace with real Google review data */
    .hero-reviews {
      display: inline-flex; align-items: center; gap: 0.55rem;
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 50px; padding: 0.4rem 0.9rem;
      margin-bottom: 1.1rem;
      font-size: 0.78rem; color: var(--mid);
    }
    .stars { color: #FBBC05; letter-spacing: 0.04em; }

    .hero-bullets {
      list-style: none;
      display: flex; flex-direction: column;
      gap: 0.45rem; margin-bottom: 1.5rem;
    }
    .hero-bullets li { display: flex; align-items: center; gap: 0.55rem; font-size: 0.875rem; color: var(--text); font-weight: 400; }
    .bullet-tick {
      width: 20px; height: 20px; flex-shrink: 0;
      background: var(--bg-card); border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: var(--accent);
    }
    .bullet-tick svg { width: 10px; height: 10px; }

    .hero-ctas {
      display: flex; gap: 0.75rem; flex-wrap: wrap;
    }

    .btn-primary {
      display: inline-flex; align-items: center; gap: 0.45rem;
      padding: 0.9rem 2rem;
      background: var(--accent); color: #fff;
      border-radius: 50px; font-size: 0.9rem; font-weight: 600;
      box-shadow: 0 4px 18px rgba(112,69,178,0.28);
      transition: all 0.25s;
    }
    .btn-primary:hover { background: var(--accent-mid); transform: translateY(-2px); box-shadow: 0 6px 24px rgba(112,69,178,0.36); }

    .btn-secondary {
      display: inline-flex; align-items: center; gap: 0.45rem;
      padding: 0.9rem 2rem;
      background: transparent; color: var(--text);
      border: 1.5px solid var(--border); border-radius: 50px;
      font-size: 0.9rem; font-weight: 600;
      transition: all 0.25s;
    }
    .btn-secondary:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }

    /* Hero portrait image area */
    .hero-visual {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: flex-end;
      padding-bottom: 0;
    }
    .hero-portrait {
      width: 320px; max-width: 100%;
      aspect-ratio: 3/4;
      border-radius: 160px 160px 20px 20px;
      background: var(--bg-card);
      position: relative;
      overflow: hidden;
      box-shadow: 0 18px 42px rgba(34,21,53,0.16);
    }
    .hero-portrait img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      object-position: center;
    }
    .hero-portrait-label {
      position: absolute; bottom: 0; left: 0; right: 0;
      background: linear-gradient(to top, rgba(34,21,53,0.85) 0%, transparent 100%);
      padding: 2rem 1.5rem 1.5rem;
      color: rgba(255,255,255,0.9);
      font-size: 0.7rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
    }
    .hero-badge {
      position: absolute; top: 1.5rem; right: -0.5rem;
      background: var(--cream); border: 1px solid var(--border);
      border-radius: 12px; padding: 0.75rem 1rem;
      box-shadow: 0 4px 16px rgba(112,69,178,0.12);
      text-align: center;
    }
    .hero-badge strong { display: block; font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.4rem; font-weight: 600; color: var(--accent); line-height: 1; }
    .hero-badge span { font-size: 0.65rem; font-weight: 500; color: var(--light); letter-spacing: 0.04em; }
    .hero-badge-2 {
      position: absolute; bottom: 1.5rem; right: -1rem;
      background: var(--accent); color: #fff;
      border-radius: 12px; padding: 0.7rem 1rem;
      box-shadow: 0 4px 14px rgba(112,69,178,0.35);
      display: flex; align-items: center; gap: 0.5rem;
      font-size: 0.75rem; font-weight: 600;
    }
    .hero-badge-2 svg { width: 14px; height: 14px; }

    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; gap: 2rem; }
      .hero-content { padding-bottom: 0; }
      .hero-visual { justify-content: flex-end; }
      .hero-portrait { width: 220px; }
      .hero-badge { top: 0.75rem; right: 0; }
      .hero-badge-2 { right: 0; }
    }
    @media (max-width: 540px) {
      .hero { padding: 2rem 0 0; }
      .hero-inner { gap: 1.5rem; }
      .hero-visual { display: none; }
      .hero-content { padding-bottom: 2.5rem; }
    }

    /* ─── TRUST BAR ─── */
    .trust-bar { background: var(--bg-dark); padding: 2rem 0; }
    .trust-inner { display: flex; justify-content: center; gap: 3rem; flex-wrap: wrap; }
    .trust-item { text-align: center; }
    .trust-item strong {
      display: block;
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 2rem; font-weight: 600; line-height: 1.1;
      color: #EDE6F5;
    }
    .trust-item span { font-size: 0.72rem; font-weight: 400; letter-spacing: 0.07em; text-transform: uppercase; color: rgba(196,168,232,0.55); }

    /* ─── SECTION HEADER ─── */
    .section-header { text-align: center; margin-bottom: 3rem; }
    .section-eyebrow { display: block; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; }
    .section-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(1.9rem, 4vw, 2.8rem); font-weight: 600; line-height: 1.2; color: var(--text); }
    .section-title em { font-style: italic; font-weight: 400; color: var(--accent); }
    .section-sub { font-size: 0.925rem; color: var(--mid); max-width: 480px; margin: 0.75rem auto 0; font-weight: 300; line-height: 1.7; }

    /* ─── SERVICES ─── */
    .services { padding: 5rem 0; background: var(--bg); }
    .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }

    .service-card {
      background: var(--cream); border: 1px solid var(--border);
      border-radius: 18px; padding: 2rem 1.75rem;
      transition: all 0.25s;
      position: relative; overflow: hidden;
    }
    .service-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--accent) 0%, #C4A8E8 100%);
      opacity: 0; transition: opacity 0.25s;
    }
    .service-card:hover { transform: translateY(-4px); box-shadow: 0 10px 28px rgba(112,69,178,0.12); border-color: var(--accent); }
    .service-card:hover::before { opacity: 1; }

    .svc-icon {
      width: 48px; height: 48px;
      background: var(--bg-card); border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      color: var(--accent); margin-bottom: 1.1rem;
    }
    .svc-icon svg { width: 22px; height: 22px; }

    .service-card h3 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.25rem; font-weight: 600; color: var(--text); margin-bottom: 0.5rem; }
    .service-card p { font-size: 0.875rem; color: var(--mid); line-height: 1.7; font-weight: 300; }

    @media (max-width: 768px) { .services-grid { grid-template-columns: 1fr; } }
    @media (min-width: 769px) and (max-width: 1000px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }

    /* ─── REVIEWS ─── */
    .reviews { background: var(--bg-card); padding: 5rem 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .reviews-score { display: flex; align-items: center; justify-content: center; gap: 1rem; margin-bottom: 3rem; }
    .big-stars { font-size: 1.5rem; color: #FBBC05; }
    .reviews-score-text strong { display: block; font-family: 'Cormorant Garamond', Georgia, serif; font-size: 2.1rem; font-weight: 600; color: var(--text); line-height: 1; }
    .reviews-score-text span { font-size: 0.8rem; color: var(--mid); }
    .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
    .review-card { background: var(--cream); border: 1px solid var(--border); border-radius: 18px; padding: 1.75rem; }
    .review-stars { color: #FBBC05; font-size: 0.9rem; margin-bottom: 0.85rem; }
    .review-card blockquote { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.08rem; font-style: italic; line-height: 1.75; color: var(--text); margin-bottom: 1.1rem; }
    .review-author { font-size: 0.82rem; font-weight: 600; color: var(--mid); }
    .review-location { font-size: 0.75rem; color: var(--light); font-weight: 300; }
    @media (max-width: 768px) { .reviews-grid { grid-template-columns: 1fr; } }

    /* ─── ABOUT ─── */
    .about { padding: 5rem 0; background: var(--bg); }
    .about-inner { display: grid; grid-template-columns: 1fr 1.2fr; gap: 5rem; align-items: center; }
    .about-visual { position: relative; }
    .about-img {
      width: 100%;
      aspect-ratio: 3/4;
      border-radius: 160px 160px 18px 18px;
      background: linear-gradient(160deg, #D4BBEE 0%, #8A58C0 45%, #3D1C6E 100%);
    }
    .about-floater {
      position: absolute; bottom: -1rem; right: -1.5rem;
      background: var(--cream); border: 1px solid var(--border);
      border-radius: 16px; padding: 1.25rem 1.5rem;
      box-shadow: 0 6px 24px rgba(112,69,178,0.1);
    }
    .about-floater p { font-size: 0.8rem; font-weight: 300; color: var(--mid); margin-bottom: 0.5rem; }
    .about-floater strong { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.2rem; font-weight: 600; color: var(--accent); }

    .about h2 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 600; line-height: 1.2; color: var(--text); margin-bottom: 1.25rem; }
    .about h2 em { font-style: italic; color: var(--accent); font-weight: 400; }
    .about-text { font-size: 0.9rem; color: var(--mid); line-height: 1.85; font-weight: 300; margin-bottom: 1rem; }
    .about-features { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; margin-top: 1.75rem; }
    .about-features li { display: flex; align-items: center; gap: 0.55rem; font-size: 0.85rem; font-weight: 500; color: var(--text); }
    .feat-check {
      width: 22px; height: 22px; flex-shrink: 0;
      background: var(--bg-card); border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: var(--accent);
    }
    .feat-check svg { width: 11px; height: 11px; }
    @media (max-width: 768px) {
      .about-inner { grid-template-columns: 1fr; gap: 2.5rem; }
      .about-img { aspect-ratio: 4/3; border-radius: 18px; }
      .about-floater { right: 0; }
    }

    /* ─── CONTACT ─── */
    .contact { background: var(--bg-mid); padding: 5rem 0; border-top: 1px solid var(--border); }
    .contact-inner { display: grid; grid-template-columns: 1fr 1.5fr; gap: 4rem; align-items: start; }
    .contact-info h2 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(1.8rem, 3.5vw, 2.5rem); font-weight: 600; line-height: 1.25; margin-bottom: 1rem; }
    .contact-info h2 em { font-style: italic; color: var(--accent); font-weight: 400; }
    .contact-info p { font-size: 0.9rem; color: var(--mid); line-height: 1.75; margin-bottom: 1.75rem; font-weight: 300; }
    .contact-details { display: flex; flex-direction: column; gap: 0.85rem; }
    .contact-detail { display: flex; align-items: center; gap: 0.75rem; font-size: 0.875rem; color: var(--mid); }
    .c-icon {
      width: 38px; height: 38px; flex-shrink: 0;
      background: var(--cream); border: 1px solid var(--border); border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      color: var(--accent);
    }
    .c-icon svg { width: 16px; height: 16px; }
    .contact-detail a { color: var(--text); font-weight: 500; }
    .contact-detail a:hover { color: var(--accent); }

    .contact-form { background: var(--cream); border: 1px solid var(--border); border-radius: 22px; padding: 2.5rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
    .form-row .form-group { margin-bottom: 0; }
    label { font-size: 0.76rem; font-weight: 600; color: var(--text); letter-spacing: 0.04em; text-transform: uppercase; }
    input, select, textarea {
      width: 100%; padding: 0.75rem 1rem;
      border: 1px solid var(--border); border-radius: 10px;
      background: var(--bg); color: var(--text);
      font-family: 'Inter', sans-serif; font-size: 0.875rem;
      outline: none; transition: border-color 0.2s, box-shadow 0.2s;
    }
    input:focus, select:focus, textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(112,69,178,0.08); }
    textarea { resize: vertical; min-height: 95px; }
    .form-submit {
      width: 100%; padding: 0.95rem;
      background: var(--accent); color: #fff;
      border: none; border-radius: 50px;
      font-family: 'Inter', sans-serif; font-size: 0.95rem; font-weight: 600; letter-spacing: 0.03em;
      cursor: pointer; margin-top: 0.5rem;
      transition: all 0.25s;
      box-shadow: 0 4px 16px rgba(112,69,178,0.28);
    }
    .form-submit:hover { background: var(--accent-mid); transform: translateY(-2px); box-shadow: 0 6px 22px rgba(112,69,178,0.38); }
    @media (max-width: 768px) { .contact-inner { grid-template-columns: 1fr; gap: 2rem; } .form-row { grid-template-columns: 1fr; } }

    /* ─── FOOTER ─── */
    footer { background: var(--bg-dark); color: #EDE6F5; padding: 4rem 0 2rem; }
    .footer-inner { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 3rem; margin-bottom: 3rem; }
    .footer-logo-name { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.5rem; font-weight: 600; margin-bottom: 0.25rem; }
    .footer-tag { font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.4; margin-bottom: 0.85rem; }
    .footer-brand p { font-size: 0.85rem; opacity: 0.5; line-height: 1.75; max-width: 280px; font-weight: 300; }
    .footer-socials { display: flex; gap: 0.5rem; margin-top: 1.25rem; }
    .footer-social {
      width: 36px; height: 36px;
      border: 1px solid rgba(196,168,232,0.18); border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      color: rgba(196,168,232,0.55); cursor: pointer; transition: all 0.2s;
    }
    .footer-social:hover { border-color: rgba(196,168,232,0.5); color: #EDE6F5; }
    .footer-social svg { width: 15px; height: 15px; }
    .footer-col h4 { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.4; margin-bottom: 1rem; }
    .footer-col ul { list-style: none; }
    .footer-col li { font-size: 0.875rem; opacity: 0.6; margin-bottom: 0.5rem; font-weight: 300; }
    .footer-col a { opacity: 0.6; transition: opacity 0.2s; }
    .footer-col a:hover { opacity: 1; }
    .footer-bottom { border-top: 1px solid rgba(196,168,232,0.1); padding-top: 1.5rem; display: flex; justify-content: space-between; font-size: 0.78rem; opacity: 0.35; }
    @media (max-width: 768px) { .footer-inner { grid-template-columns: 1fr; gap: 2rem; } .footer-bottom { flex-direction: column; gap: 0.5rem; } }

    /* ─── WHATSAPP ─── */
    .whatsapp-btn {
      position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9999;
      display: flex; align-items: center; gap: 0.55rem;
      background: #25D366; color: #fff;
      padding: 0.75rem 1.25rem; border-radius: 50px;
      box-shadow: 0 4px 16px rgba(37,211,102,0.35);
      font-size: 0.875rem; font-weight: 600;
      transition: all 0.25s;
    }
    .whatsapp-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 22px rgba(37,211,102,0.45); }
    .whatsapp-btn svg { width: 22px; height: 22px; flex-shrink: 0; }
    @media (max-width: 480px) { .whatsapp-btn { padding: 0.75rem; border-radius: 50%; } .wa-label { display: none; } }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header>
    <div class="container">
      <nav class="nav-inner">
        <a href="#" class="nav-logo">
          <span class="nav-logo-name">
            Jamie Fearn
            <small>Hypnotherapy &amp; Coaching</small>
          </span>
        </a>

        <ul class="nav-links">
          <li><a href="#services">Hypnotherapy</a></li>
          <li><a href="#services">Coaching</a></li>
          <li><a href="#reviews">Reviews</a></li>
