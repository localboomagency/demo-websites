    }, { passive: true });

    // Guest counter
    let guestCount = 2;
    const countEl = document.getElementById('guest-count');
    document.getElementById('guest-minus').addEventListener('click', () => {
      if (guestCount > 1) { guestCount--; countEl.textContent = guestCount; }
    });
    document.getElementById('guest-plus').addEventListener('click', () => {
      if (guestCount < 6) { guestCount++; countEl.textContent = guestCount; }
    });
  </script>
</body>
</html>
