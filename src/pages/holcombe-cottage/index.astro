---
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Holcombe Cottage | Luxury Seaside Accommodation in Dawlish</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    :root {
      --navy:       #0c1d2f;
      --navy-mid:   #143249;
      --cream:      #f9f5ef;
      --cream-dark: #f0ead9;
      --sand:       #c4a060;
      --sand-light: #d4b87a;
      --charcoal:   #1a1a1a;
      --mid:        #6a6360;
      --light:      #a09890;
      --border:     #e2d8c8;
    }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      font-weight: 300;
      color: var(--charcoal);
      background: var(--cream);
      line-height: 1.6;
    }
    a { text-decoration: none; color: inherit; }
    button { font-family: 'Inter', sans-serif; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

    /* ─── HEADER ─── */
    header {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      background: linear-gradient(to bottom, rgba(4,12,24,0.55) 0%, rgba(4,12,24,0.0) 100%);
      transition: background 0.4s ease, backdrop-filter 0.4s ease, box-shadow 0.4s ease;
    }
    header.scrolled {
      background: rgba(249, 245, 239, 0.97);
      backdrop-filter: blur(12px);
      box-shadow: 0 1px 0 var(--border);
    }
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 76px;
    }
    .nav-logo {
      display: flex;
      flex-direction: column;
      line-height: 1;
      gap: 3px;
    }
    .logo-main {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-weight: 400;
      font-size: 1.3rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #fff;
      transition: color 0.4s;
    }
    .logo-sub {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-weight: 300;
      font-style: italic;
      font-size: 0.76rem;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.6);
      transition: color 0.4s;
    }
    header.scrolled .logo-main { color: var(--charcoal); }
    header.scrolled .logo-sub  { color: var(--mid); }

    nav {
      display: flex;
      align-items: center;
      gap: 2.25rem;
    }
    nav a {
      font-size: 0.74rem;
      font-weight: 400;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.8);
      transition: color 0.25s;
    }
    nav a:hover { color: #fff; }
    header.scrolled nav a { color: var(--mid); }
    header.scrolled nav a:hover { color: var(--charcoal); }

    .nav-enquire {
      font-size: 0.72rem;
      font-weight: 400;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.5rem 1.4rem;
      border: 1px solid rgba(255,255,255,0.45);
      color: #fff;
      background: transparent;
      cursor: pointer;
      transition: all 0.25s;
    }
    .nav-enquire:hover { background: rgba(255,255,255,0.1); border-color: #fff; }
    header.scrolled .nav-enquire { border-color: var(--charcoal); color: var(--charcoal); }
    header.scrolled .nav-enquire:hover { background: var(--charcoal); color: #fff; }

    .nav-hamburger {
      display: none;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 5px;
      width: 40px;
      height: 40px;
      background: transparent;
      border: 1px solid rgba(255,255,255,0.35);
      cursor: pointer;
      padding: 0;
    }
    .nav-hamburger span {
      display: block;
      width: 18px;
      height: 1px;
      background: #fff;
      transition: background 0.4s;
    }
    header.scrolled .nav-hamburger { border-color: var(--border); }
    header.scrolled .nav-hamburger span { background: var(--charcoal); }

    /* ─── HERO ─── */
    .hero {
      position: relative;
      min-height: 100svh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background:
        linear-gradient(160deg, rgba(6,15,26,0.16) 0%, rgba(12,29,47,0.18) 100%),
        url('/images/holcombe-cottage/hero.png') center/cover no-repeat;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(4,12,24,0.58) 0%,
        rgba(4,12,24,0.48) 45%,
        rgba(4,12,24,0.72) 100%
      );
    }
    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 50% 0%, rgba(196,160,96,0.07) 0%, transparent 65%);
      pointer-events: none;
    }

    .hero-inner {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 96px 2rem 5rem;
      width: 100%;
      max-width: 860px;
      margin: 0 auto;
    }

    .hero-eyebrow {
      font-size: 0.68rem;
      font-weight: 400;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--sand-light);
      margin-bottom: 1.1rem;
    }

    .hero h1 {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-weight: 300;
      font-style: italic;
      font-size: clamp(3rem, 8vw, 5.5rem);
      line-height: 1.05;
      color: #fff;
      margin-bottom: 0.4rem;
      letter-spacing: -0.01em;
    }

    .hero-subtitle {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: clamp(0.95rem, 2.2vw, 1.25rem);
      font-weight: 300;
      color: rgba(255,255,255,0.88);
      letter-spacing: 0.06em;
      margin-bottom: 1.75rem;
    }

    /* Booking widget */
    .booking-widget {
      background: rgba(249,245,239,0.97);
      backdrop-filter: blur(16px);
      border-radius: 3px;
      display: flex;
      align-items: stretch;
      overflow: hidden;
      box-shadow: 0 24px 64px rgba(0,0,0,0.38), 0 4px 16px rgba(0,0,0,0.18);
      max-width: 780px;
      margin: 0 auto;
    }
    .booking-field {
      flex: 1;
      padding: 1rem 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      border-right: 1px solid var(--border);
    }
    .booking-field:last-of-type { border-right: none; }
    .booking-field label {
      font-size: 0.62rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--mid);
    }
    .booking-field input[type="date"] {
      border: none;
      background: transparent;
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.05rem;
      font-weight: 400;
      color: var(--charcoal);
      padding: 0;
      outline: none;
      width: 100%;
      cursor: pointer;
    }
    .guest-row {
      display: flex;
      align-items: center;
      gap: 0;
    }
    .guest-count {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.05rem;
      font-weight: 400;
      color: var(--charcoal);
      width: 2rem;
      text-align: center;
    }
    .guest-btn {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--mid);
      width: 26px;
      height: 26px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 1.1rem;
      line-height: 1;
      font-weight: 300;
      transition: all 0.2s;
    }
    .guest-btn:hover { border-color: var(--charcoal); color: var(--charcoal); }
    .booking-cta-btn {
      padding: 0 2rem;
      background: var(--navy);
      color: #fff;
      border: none;
      cursor: pointer;
      font-size: 0.72rem;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      white-space: nowrap;
      min-width: 155px;
      transition: background 0.25s;
    }
    .booking-cta-btn:hover { background: var(--navy-mid); }

    /* Scroll indicator */
    .hero-scroll {
      position: absolute;
      bottom: 1.75rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.4rem;
      color: rgba(255,255,255,0.4);
      font-size: 0.6rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      z-index: 1;
    }
    .scroll-line {
      width: 1px;
      height: 30px;
      background: linear-gradient(to bottom, rgba(255,255,255,0.55), transparent);
      animation: scrollPulse 2.2s ease-in-out infinite;
    }
    @keyframes scrollPulse {
      0%, 100% { opacity: 0.4; }
      50% { opacity: 1; }
    }

    /* ─── SHARED SECTION STYLES ─── */
    section { padding: 5.5rem 0; }
    .section-label {
      font-size: 0.65rem;
      font-weight: 400;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--sand);
      margin-bottom: 0.9rem;
    }
    h2 {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-weight: 400;
      font-size: clamp(1.9rem, 3.5vw, 2.6rem);
      line-height: 1.2;
      color: var(--charcoal);
    }
    .section-rule {
      width: 36px;
      height: 1px;
      background: var(--sand);
      margin: 1.4rem 0;
    }

    /* ─── ABOUT ─── */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }
    .about-body {
      font-size: 0.97rem;
      line-height: 1.85;
      color: #4a4340;
    }
    .about-body p + p { margin-top: 1.2rem; }

    .about-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
    }
    .stat-item {
      background: var(--cream);
      padding: 1.75rem 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    .stat-label {
      font-size: 0.62rem;
      font-weight: 500;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--mid);
    }
    .stat-value {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.5rem;
      font-weight: 400;
      color: var(--charcoal);
      line-height: 1.2;
    }

    /* ─── AMENITIES ─── */
    .amenities-section { background: var(--navy); }
    .amenities-section .section-label { color: var(--sand-light); }
    .amenities-section h2 { color: #fff; }
    .amenities-section .section-rule { background: rgba(255,255,255,0.2); }

    .amenities-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border: 1px solid rgba(255,255,255,0.08);
      margin-top: 3rem;
    }
    .amenity {
      padding: 2.5rem 2rem;
      border-right: 1px solid rgba(255,255,255,0.08);
      border-bottom: 1px solid rgba(255,255,255,0.08);
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
    }
    .amenity:nth-child(3n) { border-right: none; }
    .amenity:nth-child(n+4) { border-bottom: none; }
    .amenity-icon { color: var(--sand); }
    .amenity-icon svg { width: 26px; height: 26px; }
    .amenity-name {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.15rem;
      font-weight: 400;
      color: #fff;
    }
    .amenity-desc {
      font-size: 0.8rem;
      line-height: 1.55;
      color: rgba(255,255,255,0.68);
    }

    /* ─── GALLERY ─── */
    .gallery-header { margin-bottom: 2.5rem; }
    .gallery-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      grid-template-rows: 250px 250px;
      gap: 0.4rem;
    }
    .gallery-item {
      background: var(--cream-dark);
      position: relative;
      overflow: hidden;
    }
    .gallery-item:first-child { grid-row: span 2; }
    /* PLACEHOLDER: add background-image to each .gallery-item when images are available */
    .gallery-label {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--light);
      font-size: 0.62rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    /* ─── REVIEWS ─── */
    .reviews-section { background: var(--cream-dark); }

    .reviews-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 2rem;
      margin-bottom: 3rem;
      flex-wrap: wrap;
    }
    .ta-score-block {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      background: var(--cream);
      border: 1px solid var(--border);
      padding: 1.5rem 2rem;
    }
    .ta-score-num {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 3.2rem;
      font-weight: 300;
      line-height: 1;
      color: var(--charcoal);
    }
    .ta-score-info { display: flex; flex-direction: column; gap: 0.3rem; }
    .ta-score-label {
      font-size: 0.68rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--mid);
    }
    .ta-score-bubbles { display: flex; gap: 3px; }
    .ta-score-bubbles .tb { width: 13px; height: 13px; border-radius: 50%; background: #34E0A1; }
    .ta-cert {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.78rem;
      color: var(--mid);
    }
    .ta-cert svg { width: 15px; height: 15px; color: #34E0A1; }

    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
    .review-card {
      background: var(--cream);
      border: 1px solid var(--border);
      padding: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .rev-bubbles { display: flex; gap: 3px; }
    .rev-bubbles .rb { width: 11px; height: 11px; border-radius: 50%; background: #34E0A1; }
    .rev-quote {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.05rem;
      font-style: italic;
      color: var(--charcoal);
      line-height: 1.65;
      flex: 1;
    }
    .rev-meta { display: flex; flex-direction: column; gap: 0.2rem; }
    .rev-name {
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--charcoal);
      letter-spacing: 0.02em;
    }
    .rev-date {
      font-size: 0.72rem;
      color: var(--mid);
    }

    /* ─── ENQUIRE ─── */
    .enquire-grid {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 5rem;
      align-items: start;
    }
    .enquire-intro {
      font-size: 0.95rem;
      line-height: 1.85;
      color: #4a4340;
      margin-top: 1rem;
    }
    .enquire-detail {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      margin-top: 1.75rem;
      font-size: 0.88rem;
      color: var(--mid);
    }
    .enquire-detail svg { width: 17px; height: 17px; color: var(--sand); flex-shrink: 0; margin-top: 0.1rem; }

    form { display: flex; flex-direction: column; gap: 0.9rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.9rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.35rem; }
    .form-group label {
      font-size: 0.62rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--mid);
    }
    .form-group input,
    .form-group textarea,
    .form-group select {
      border: 1px solid var(--border);
      background: #fff;
      padding: 0.8rem 1rem;
      font-family: 'Inter', sans-serif;
      font-size: 0.88rem;
      font-weight: 300;
      color: var(--charcoal);
      outline: none;
      transition: border-color 0.2s;
      border-radius: 0;
      -webkit-appearance: none;
      width: 100%;
    }
    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus { border-color: var(--sand); }
    .form-group textarea { resize: vertical; min-height: 100px; }

    .btn-submit {
      align-self: flex-start;
      padding: 0.9rem 2.5rem;
      background: var(--navy);
      color: #fff;
      border: none;
      cursor: pointer;
      font-size: 0.72rem;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      transition: background 0.25s;
      margin-top: 0.25rem;
    }
    .btn-submit:hover { background: var(--navy-mid); }

    /* ─── FOOTER ─── */
    footer {
      background: #111820;
      color: rgba(255,255,255,0.62);
      padding: 3.5rem 0 2rem;
    }
    .footer-inner {
      display: grid;
      grid-template-columns: 1.6fr 1fr 1fr;
      gap: 3rem;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .fb-name {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.25rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #fff;
      margin-bottom: 0.2rem;
    }
    .fb-tagline {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-style: italic;
      font-size: 0.85rem;
      color: rgba(255,255,255,0.4);
      margin-bottom: 1.25rem;
    }
    .fb-address {
      font-size: 0.82rem;
      line-height: 1.8;
    }
    .footer-social {
      display: flex;
      gap: 0.65rem;
      margin-top: 1.5rem;
    }
    .soc-icon {
      width: 34px;
      height: 34px;
      border: 1px solid rgba(255,255,255,0.12);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: border-color 0.2s;
    }
    .soc-icon:hover { border-color: rgba(255,255,255,0.35); }
    .soc-icon svg { width: 15px; height: 15px; color: rgba(255,255,255,0.5); }

    .footer-col h4 {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #fff;
      margin-bottom: 1.25rem;
    }
    .footer-col ul { list-style: none; }
    .footer-col ul li { margin-bottom: 0.6rem; font-size: 0.83rem; }
    .footer-col a:hover { color: rgba(255,255,255,0.75); }

    .footer-bottom {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 1.75rem;
      font-size: 0.74rem;
    }

    /* ─── WHATSAPP ─── */
    /* PLACEHOLDER: replace wa.me number with real WhatsApp number */
    .whatsapp-float {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 9999;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: #25D366;
      color: #fff;
      padding: 0.65rem 1.1rem 0.65rem 0.65rem;
      border-radius: 50px;
      box-shadow: 0 4px 20px rgba(37,211,102,0.38);
      font-size: 0.8rem;
      font-weight: 400;
      letter-spacing: 0.02em;
      transition: transform 0.25s, box-shadow 0.25s;
    }
    .whatsapp-float:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 26px rgba(37,211,102,0.5);
    }
    .whatsapp-float svg { width: 24px; height: 24px; flex-shrink: 0; }
    @media (max-width: 480px) {
      .whatsapp-label { display: none; }
      .whatsapp-float { padding: 0.65rem; border-radius: 50%; }
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 768px) {
      nav, .nav-enquire { display: none; }
      .nav-hamburger { display: flex; }

      .hero-inner { padding: 88px 1.5rem 4rem; }

      .booking-widget {
        display: grid;
        grid-template-columns: 1fr 1fr;
        max-width: 100%;
        border-radius: 8px;
      }
      .booking-field {
        border-right: none;
        border-bottom: 1px solid var(--border);
        padding: 1.1rem 1.2rem;
      }
      .booking-widget .booking-field:first-child {
        border-right: 1px solid var(--border);
      }
      .booking-widget .booking-field:nth-child(3) {
        grid-column: span 2;
        border-bottom: none;
      }
      .booking-field input[type="date"] { font-size: 0.95rem; }
      .booking-cta-btn {
        grid-column: span 2;
        padding: 1.25rem 1.5rem;
        min-width: auto;
        font-size: 0.75rem;
        letter-spacing: 0.2em;
        width: 100%;
        border-radius: 0 0 8px 8px;
      }
      .guest-btn { width: 38px; height: 38px; font-size: 1.2rem; }

      .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      .about-stats { grid-template-columns: 1fr 1fr; }

      .amenities-grid { grid-template-columns: 1fr 1fr; }
      .amenity:nth-child(2n) { border-right: none; }
      .amenity:nth-child(3n) { border-right: 1px solid rgba(255,255,255,0.08); }
