    <!-- 3. TRUST BAR -->
    <div class="trust-bar">
      <div class="container trust-inner">
        <div class="trust-item">
          <span class="trust-num">37</span>
          <span class="trust-label">Years trading</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="trust-num">12+</span>
          <span class="trust-label">Breads baked daily</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="trust-num">4.9&#9733;</span>
          <span class="trust-label">214 Google reviews</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="trust-num">3am</span>
          <span class="trust-label">When we start</span>
        </div>
      </div>
