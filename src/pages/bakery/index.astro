        <!-- PLACEHOLDER: replace gallery-cell divs with <img> tags at /images/bakery/product-[1-4].jpg -->
        <div class="hero-gallery">
          <div class="gallery-cell"></div>
          <div class="gallery-cell"></div>
          <div class="gallery-cell"></div>
          <div class="gallery-cell"></div>
