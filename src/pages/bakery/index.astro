    <!-- 2. HERO -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-content">
          <p class="eyebrow">Handcrafted Since 1987</p>
          <h1>Artisan Bakery<br />in Thornbury</h1>
          <p class="hero-sub">Stone-milled flour, wild-yeast starters, and 37 years of craft. Every loaf baked by hand before the town wakes up.</p>
          <ul class="hero-bullets">
            <li>Stone-milled flour from a Shropshire family mill</li>
            <li>48-hour cold ferments &mdash; no shortcuts, ever</li>
            <li>Baked fresh every morning from 3am</li>
          </ul>
          <!-- PLACEHOLDER: replace with real Google review data -->
          <div class="google-review">
            <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#4285F4" d="M43.6 20.1H42V20H24v8h11.3C33.7 32.9 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.1 8 2.9l5.7-5.7C34.5 6.5 29.5 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.6-.4-3.9z"/><path fill="#EA4335" d="M6.3 14.7l6.6 4.8C14.6 16.1 19 13 24 13c3.1 0 5.8 1.1 8 2.9l5.7-5.7C34.5 6.5 29.5 4 24 4 16.3 4 9.7 8.4 6.3 14.7z"/><path fill="#FBBC05" d="M24 44c5.2 0 9.9-1.9 13.4-5.1l-6.2-5.2C29.3 35.3 26.8 36 24 36c-5.2 0-9.7-3.1-11.3-7.9l-6.5 5.1C9.6 39.5 16.3 44 24 44z"/><path fill="#34A853" d="M43.6 20.1H42V20H24v8h11.3c-.8 2.3-2.3 4.2-4.3 5.6l6.2 5.2C37 39 44 33 44 24c0-1.3-.1-2.6-.4-3.9z"/></svg>
            <span class="review-stars-hero">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span class="review-text-hero">4.9 &nbsp;&middot;&nbsp; 214 reviews on Google</span>
          </div>
          <div class="hero-actions">
            <a href="tel:01454567890" class="btn-primary">
