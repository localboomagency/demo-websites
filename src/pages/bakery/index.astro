    <!-- 4. SERVICES -->
    <section class="services" id="menu">
      <div class="container">
        <span class="label">Baked Fresh Daily</span>
        <h2>What we make</h2>
        <div class="services-grid">
          <div class="service-card">
            <span class="service-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="12" y1="20" x2="12" y2="4"/><path d="M12 8c0-2-2-4-4-4 0 2 2 4 4 4z"/><path d="M12 8c0-2 2-4 4-4 0 2-2 4-4 4z"/><path d="M12 13c0-2-2-4-4-4 0 2 2 4 4 4z"/><path d="M12 13c0-2 2-4 4-4 0 2-2 4-4 4z"/></svg></span>
            <h3>Country Sourdough</h3>
            <p>Our original. 48-hour cold ferment, open crumb, blistered crust. Made with the same starter since 1987.</p>
            <span class="price">from &pound;6.50</span>
          </div>
          <div class="service-card">
            <span class="service-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg></span>
            <h3>Butter Croissants</h3>
            <p>Laminated with French beurre de qualit&eacute;. Honey-gold layers, shattering crust, cloud-soft inside.</p>
            <span class="price">from &pound;3.20</span>
          </div>
          <div class="service-card">
            <span class="service-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M17 8C8 10 5.9 16.17 3.82 19.49c-.51.84.18 1.84 1.17 1.6C15.6 18.67 20.25 12.33 17 8z"/><path d="M3.82 19.49L8 15"/></svg></span>
            <h3>Seeded Rye</h3>
            <p>Dense, earthy, and deeply flavoured. Topped with sunflower, pumpkin, and sesame. Extraordinary with smoked salmon.</p>
            <span class="price">from &pound;5.80</span>
          </div>
          <div class="service-card">
            <span class="service-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg></span>
            <h3>Lemon Tart</h3>
            <p>Buttery blind-baked shell, sharp curd made with unwaxed lemons, finished with a veil of icing sugar.</p>
            <span class="price">&pound;4.50</span>
          </div>
          <div class="service-card">
            <span class="service-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="7" width="18" height="10" rx="2"/><circle cx="8" cy="12" r="1" fill="currentColor" stroke="none"/><circle cx="12" cy="12" r="1" fill="currentColor" stroke="none"/><circle cx="16" cy="12" r="1" fill="currentColor" stroke="none"/><circle cx="10" cy="9.5" r="1" fill="currentColor" stroke="none"/><circle cx="14" cy="9.5" r="1" fill="currentColor" stroke="none"/><circle cx="10" cy="14.5" r="1" fill="currentColor" stroke="none"/><circle cx="14" cy="14.5" r="1" fill="currentColor" stroke="none"/></svg></span>
            <h3>Rosemary Focaccia</h3>
            <p>Dimpled, oiled, fragrant. Scattered with Maldon sea salt and fresh rosemary. Baked until deeply golden.</p>
            <span class="price">&pound;4.00</span>
          </div>
          <div class="service-card">
            <span class="service-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M9 6V4M12 6V3M15 6V4"/><rect x="5" y="6" width="14" height="5" rx="1"/><rect x="3" y="11" width="18" height="7" rx="1"/></svg></span>
            <h3>Celebration Cakes</h3>
            <p>Bespoke cakes made to order. Give us 48 hours and your brief &mdash; we&rsquo;ll bake something you won&rsquo;t forget.</p>
            <span class="price">from &pound;45</span>
          </div>
        </div>
      </div>
    </section>

    <!-- 5. REVIEWS -->
    <section class="reviews">
      <div class="container">
        <div class="reviews-header">
          <div>
            <span class="label">What people say</span>
            <h2>214 five-star reviews</h2>
          </div>
          <div class="rating-badge">
            <span class="rating-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span class="rating-score">4.9 on Google</span>
          </div>
        </div>
        <!-- PLACEHOLDER: replace with real reviews -->
        <div class="reviews-grid">
          <div class="review-card">
            <div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <blockquote>&ldquo;The sourdough is absolutely incredible. I drive past three other bakeries to get here every Saturday. The crust shatters, the crumb is perfect &mdash; nothing in the county comes close.&rdquo;</blockquote>
            <div class="reviewer">
              <span class="reviewer-name">Sarah M.</span>
              <span class="reviewer-location">Thornbury</span>
            </div>
          </div>
          <div class="review-card">
            <div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <blockquote>&ldquo;We&rsquo;ve ordered croissants for our office every Friday for six months. Never a single disappointment. The lamination is genuinely exceptional &mdash; better than anything I&rsquo;ve had in Paris.&rdquo;</blockquote>
            <div class="reviewer">
              <span class="reviewer-name">James R.</span>
              <span class="reviewer-location">Bristol</span>
            </div>
          </div>
          <div class="review-card">
            <div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <blockquote>&ldquo;The lemon tart is the best thing I&rsquo;ve eaten in years. Proper pastry, proper curd, the right amount of sharp. I came in for bread and left spending &pound;30. Worth every penny.&rdquo;</blockquote>
            <div class="reviewer">
              <span class="reviewer-name">Helen T.</span>
              <span class="reviewer-location">Chepstow</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 6. WHY US / ABOUT -->
    <section class="about" id="story">
      <div class="container">
        <div class="about-grid">
          <div class="about-text">
            <span class="label">Our Story</span>
            <h2>A family tradition, still baked by hand</h2>
            <p>It started in a small kitchen in 1987, with my grandmother&rsquo;s sourdough starter &mdash; a culture she&rsquo;d kept alive for decades. Today we use those same techniques: long cold ferments, hand-scoring, and stone-deck ovens that create the crust you simply can&rsquo;t replicate at home.</p>
            <p>Every morning our bakers arrive at 3am. By the time you walk in, the shelves are warm and the town smells like bread.</p>
          </div>
          <div class="about-facts">
            <div class="fact">
              <span class="fact-num">01</span>
              <div class="fact-body">
                <strong>Stone-milled flour</strong>
                <p>Sourced from a family mill in Shropshire. Better flavour, full traceability from field to loaf.</p>
              </div>
            </div>
            <div class="fact">
              <span class="fact-num">02</span>
              <div class="fact-body">
                <strong>48-hour ferments</strong>
                <p>Cold-retarding overnight develops flavour compounds that fast baking never achieves.</p>
              </div>
            </div>
            <div class="fact">
              <span class="fact-num">03</span>
              <div class="fact-body">
                <strong>Local suppliers only</strong>
                <p>Our butter, eggs, and dairy all come from within 30 miles. We know the farms.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 7. CONTACT / QUOTE FORM -->
    <section class="contact" id="enquiries">
      <div class="container">
        <div class="contact-grid">
          <div class="contact-info">
            <span class="label">Get in Touch</span>
            <h2>Pre-orders, wholesale &amp; catering</h2>
            <p>Planning a wedding or event? Need bread for your caf&eacute; or deli? Want to pre-order for the weekend? Drop us a message and we&rsquo;ll get back to you same day.</p>
            <ul class="contact-details">
              <li>
                <span class="detail-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
                <span>14 Millstone Lane, Thornbury, BS35 2AA</span>
              </li>
              <li>
                <span class="detail-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
                <a href="tel:01454567890">01454 567890</a>
                <!-- PLACEHOLDER: phone number -->
              </li>
              <li>
                <span class="detail-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span>
                <a href="mailto:hello@artisanbakery.co.uk">hello@artisanbakery.co.uk</a>
              </li>
              <li>
                <span class="detail-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
                <span>Tuesday &ndash; Sunday &nbsp;&middot;&nbsp; 7am &ndash; 5pm</span>
              </li>
            </ul>
          </div>
          <form class="contact-form">
            <div class="form-row">
              <div class="form-group">
                <label for="name">Your name</label>
                <input type="text" id="name" name="name" placeholder="Jane Smith" required />
              </div>
              <div class="form-group">
                <label for="phone">Phone number</label>
                <input type="tel" id="phone" name="phone" placeholder="07700 900000" />
              </div>
            </div>
            <div class="form-group">
              <label for="email">Email address</label>
              <input type="email" id="email" name="email" placeholder="jane@example.com" required />
            </div>
            <div class="form-group">
              <label for="message">What do you need?</label>
              <textarea id="message" name="message" rows="5" placeholder="Tell us about your order, event, or enquiry&hellip;"></textarea>
            </div>
            <button type="submit" class="btn-submit">Send Enquiry</button>
          </form>
        </div>
      </div>
    </section>

