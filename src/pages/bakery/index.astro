---
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>The Artisan Bakery — Handcrafted Since 1987</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@300;400&display=swap" rel="stylesheet" />
  </head>
  <body>

    <nav>
      <div class="nav-inner">
        <a href="/" class="back-link">&#8592; Back to demos</a>
        <span class="logo">The Artisan Bakery</span>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-inner">
        <p class="eyebrow">Handcrafted Since 1987</p>
        <h1>Bread baked<br />with love and<br />tradition.</h1>
        <p class="hero-sub">Using stone-milled flour, wild yeast starters, and recipes passed down through generations. Every loaf tells a story.</p>
        <div class="hero-actions">
          <a href="#menu" class="btn-primary">View Our Menu</a>
          <a href="#story" class="btn-ghost">Our Story</a>
        </div>
      </div>
    </section>

    <div class="banner">
      <p>Open Tuesday – Sunday &nbsp;·&nbsp; 7am to 5pm &nbsp;·&nbsp; 14 Millstone Lane, Thornbury</p>
    </div>

    <section class="story" id="story">
      <div class="container">
        <div class="story-grid">
          <div class="story-text">
            <span class="label">Our Story</span>
            <h2>A family tradition, still baked by hand</h2>
            <p>It started in a small kitchen in 1987, with my grandmother's sourdough starter — a culture she'd kept alive for decades. Today we use those same techniques: long cold ferments, hand-scoring, and stone-deck ovens that create the crust you simply can't replicate at home.</p>
            <p>Every morning, our bakers arrive at 3am. By the time you walk in, the shelves are warm.</p>
          </div>
          <div class="story-visual">
            <div class="visual-block">
              <span class="visual-stat">37</span>
              <span class="visual-label">Years of baking</span>
            </div>
            <div class="visual-block">
              <span class="visual-stat">12</span>
              <span class="visual-label">Breads baked daily</span>
            </div>
            <div class="visual-block">
              <span class="visual-stat">3am</span>
              <span class="visual-label">When we start</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="menu" id="menu">
      <div class="container">
        <span class="label">Baked Fresh Daily</span>
        <h2>Signature Items</h2>
        <div class="menu-grid">
          <div class="menu-card">
            <span class="menu-icon">&#127838;</span>
            <h3>Country Sourdough</h3>
            <p>Our original. 48-hour cold ferment, open crumb, blistered crust. A classic that never changes.</p>
            <span class="price">&pound;6.50</span>
          </div>
          <div class="menu-card">
            <span class="menu-icon">&#129360;</span>
            <h3>Butter Croissant</h3>
            <p>Laminated with French beurre de qualit&eacute;. Honey-gold, shattering layers, soft inside.</p>
            <span class="price">&pound;3.20</span>
          </div>
          <div class="menu-card">
            <span class="menu-icon">&#129395;</span>
            <h3>Seeded Rye</h3>
            <p>Dense, earthy, and rich. Topped with sunflower, pumpkin, and sesame. Perfect with smoked salmon.</p>
            <span class="price">&pound;5.80</span>
          </div>
          <div class="menu-card">
            <span class="menu-icon">&#127856;</span>
            <h3>Lemon Tart</h3>
            <p>Buttery blind-baked shell, sharp curd made with unwaxed lemons, dusted with icing sugar.</p>
            <span class="price">&pound;4.50</span>
          </div>
          <div class="menu-card">
            <span class="menu-icon">&#129400;</span>
            <h3>Rosemary Focaccia</h3>
            <p>Dimpled, oiled, and fragrant. Scattered with sea salt and fresh rosemary. Baked until golden.</p>
            <span class="price">&pound;4.00</span>
          </div>
          <div class="menu-card">
            <span class="menu-icon">&#9749;</span>
            <h3>Morning Coffee</h3>
            <p>Single-origin espresso from our neighbours at Roast &amp; Co. Perfect with a warm pastry.</p>
            <span class="price">&pound;3.00</span>
          </div>
        </div>
      </div>
    </section>

    <section class="cta">
      <div class="container">
        <h2>Find us on Millstone Lane</h2>
        <p>We&rsquo;re open six days a week. Come early &mdash; we often sell out by midday.</p>
        <a href="#" class="btn-primary">Get Directions</a>
      </div>
    </section>

    <footer>
      <div class="container">
        <p class="footer-logo">The Artisan Bakery</p>
        <p>14 Millstone Lane, Thornbury &nbsp;&middot;&nbsp; hello@artisanbakery.co.uk</p>
        <p class="footer-note">&copy; 2024 The Artisan Bakery &nbsp;&middot;&nbsp; <a href="/">Back to demos</a></p>
      </div>
    </footer>

  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #fdf8f2;
    --warm-white: #fffdf9;
    --terracotta: #c67c52;
    --terracotta-dark: #a8623f;
    --brown: #3d2c1e;
    --mid: #6b5344;
    --border: #e8ddd4;
    --serif: 'Playfair Display', Georgia, serif;
    --sans: 'Lato', sans-serif;
  }

  body {
    font-family: var(--sans);
    background: var(--warm-white);
    color: var(--brown);
    line-height: 1.7;
  }

  /* ── Nav ── */
  nav {
    position: sticky;
    top: 0;
    background: rgba(253, 248, 242, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    z-index: 100;
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .back-link {
    font-size: 0.875rem;
    color: var(--mid);
    text-decoration: none;
  }
  .back-link:hover { color: var(--brown); }

  .logo {
    font-family: var(--serif);
    font-size: 1.125rem;
    font-weight: 600;
  }

  /* ── Hero ── */
  .hero {
    background: var(--cream);
    padding: 100px 24px 80px;
    border-bottom: 1px solid var(--border);
  }

  .hero-inner { max-width: 680px; margin: 0 auto; }

  .eyebrow {
    font-size: 0.8125rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 20px;
    display: block;
    font-weight: 400;
  }

  .hero h1 {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.15;
    margin-bottom: 24px;
    font-weight: 700;
  }

  .hero-sub {
    font-size: 1.0625rem;
    color: var(--mid);
    max-width: 520px;
    margin-bottom: 40px;
    font-weight: 300;
  }

  .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }

  .btn-primary {
    display: inline-block;
    background: var(--terracotta);
    color: #fff;
    padding: 14px 32px;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.9375rem;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: var(--terracotta-dark); }

  .btn-ghost {
    display: inline-block;
    color: var(--brown);
    padding: 14px 24px;
    text-decoration: none;
    font-size: 0.9375rem;
    border-bottom: 1px solid var(--border);
    transition: border-color 0.2s;
  }
  .btn-ghost:hover { border-color: var(--brown); }

  /* ── Banner ── */
  .banner {
    background: var(--brown);
    color: var(--cream);
    text-align: center;
    padding: 14px 24px;
    font-size: 0.875rem;
    letter-spacing: 0.04em;
    font-weight: 300;
  }

  /* ── Shared ── */
  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

  .label {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 12px;
    font-weight: 400;
  }

  /* ── Story ── */
  .story { padding: 96px 24px; }

  .story-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .story-text h2 {
    font-family: var(--serif);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.25;
    margin-bottom: 24px;
    font-weight: 600;
  }

  .story-text p { color: var(--mid); font-weight: 300; margin-bottom: 16px; }

  .story-visual { display: flex; flex-direction: column; gap: 2px; }

  .visual-block {
    background: var(--cream);
    border: 1px solid var(--border);
    padding: 28px 32px;
    display: flex;
    flex-direction: column;
  }

  .visual-stat {
    font-family: var(--serif);
    font-size: 3rem;
    font-weight: 700;
    color: var(--terracotta);
    line-height: 1;
  }

  .visual-label {
    font-size: 0.875rem;
    color: var(--mid);
    margin-top: 6px;
    font-weight: 300;
    letter-spacing: 0.04em;
  }

  /* ── Menu ── */
  .menu {
    padding: 96px 24px;
    background: var(--cream);
    border-top: 1px solid var(--border);
  }

  .menu h2 {
    font-family: var(--serif);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    margin-bottom: 48px;
    font-weight: 600;
  }

  .menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2px;
  }

  .menu-card {
    background: var(--warm-white);
    padding: 32px 28px;
    border: 1px solid var(--border);
  }

  .menu-icon { font-size: 1.75rem; display: block; margin-bottom: 16px; }

  .menu-card h3 {
    font-family: var(--serif);
    font-size: 1.1875rem;
    margin-bottom: 10px;
    font-weight: 600;
  }

  .menu-card p {
    font-size: 0.9375rem;
    color: var(--mid);
    font-weight: 300;
    line-height: 1.65;
    margin-bottom: 20px;
  }

  .price {
    font-size: 1.0625rem;
    color: var(--terracotta);
    font-family: var(--serif);
  }

  /* ── CTA ── */
  .cta {
    padding: 96px 24px;
    text-align: center;
    background: var(--brown);
    color: var(--cream);
  }

  .cta h2 {
    font-family: var(--serif);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    margin-bottom: 16px;
    font-weight: 600;
  }

  .cta p {
    color: #c4b2a6;
    font-weight: 300;
    margin-bottom: 36px;
    font-size: 1.0625rem;
  }

  /* ── Footer ── */
  footer {
    background: #2a1c12;
    color: #a0876e;
    padding: 40px 24px;
    text-align: center;
    font-size: 0.875rem;
    font-weight: 300;
  }

  .footer-logo {
    font-family: var(--serif);
    font-size: 1.25rem;
    color: var(--cream);
    margin-bottom: 12px;
    font-weight: 600;
    display: block;
  }

  footer p { margin-bottom: 8px; }
  .footer-note { margin-top: 20px; font-size: 0.8125rem; }
  footer a { color: var(--terracotta); text-decoration: none; }
  footer a:hover { text-decoration: underline; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero { padding: 72px 24px 60px; }
    .story-grid { grid-template-columns: 1fr; gap: 48px; }
    .story-visual { flex-direction: row; }
    .visual-block { padding: 20px; }
    .visual-stat { font-size: 2rem; }
    .story, .menu, .cta { padding: 64px 24px; }
  }

  @media (max-width: 480px) {
    .story-visual { flex-direction: column; }
    .hero-actions { flex-direction: column; }
  }
</style>
