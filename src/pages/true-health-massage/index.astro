<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>True Health Massage | Massage &amp; Soft Tissue Therapy in Paignton</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    :root {
      --bg:       #FAF8F4;
      --bg-card:  #F2EDE6;
      --bg-dark:  #1C3828;
      --text:     #1A2820;
      --mid:      #4D6558;
      --light:    #7A9487;
      --border:   #DDD5C8;
      --accent:   #C45B2A;
      --accent-h: #A84A20;
      --cream:    #FDFBF8;
    }

    body { font-family: 'DM Sans', system-ui, sans-serif; color: var(--text); background: var(--bg); line-height: 1.6; }
    a { text-decoration: none; color: inherit; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

    /* NAV */
    header { background: var(--bg); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 200; }
    .nav-inner { display: grid; grid-template-columns: auto 1fr auto; align-items: center; height: 68px; gap: 1rem; }

    .nav-logo { display: flex; align-items: center; gap: 0.6rem; flex-shrink: 0; }
    .nav-logo-icon {
      width: 32px; height: 32px;
      background: var(--bg-dark); border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      color: #fff; flex-shrink: 0;
    }
    .nav-logo-icon svg { width: 16px; height: 16px; }
    .nav-logo-name { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.35rem; font-weight: 600; color: var(--text); line-height: 1.1; }
    .nav-logo-sub { font-size: 0.6rem; font-weight: 400; letter-spacing: 0.08em; text-transform: uppercase; color: var(--mid); }

    .nav-links { display: flex; gap: 2rem; list-style: none; justify-content: center; }
    .nav-links a { font-size: 0.875rem; font-weight: 500; color: var(--mid); letter-spacing: 0.02em; transition: color 0.2s; }
    .nav-links a:hover { color: var(--text); }

    .nav-right { display: flex; align-items: center; gap: 0.6rem; flex-shrink: 0; }

    .btn-nav-phone {
      display: flex; align-items: center; gap: 0.4rem;
      padding: 0.5rem 1.1rem;
      border: 1.5px solid var(--bg-dark); border-radius: 50px;
      font-size: 0.85rem; font-weight: 600; color: var(--bg-dark);
      transition: all 0.2s; white-space: nowrap;
    }
    .btn-nav-phone svg { width: 12px; height: 12px; }
    .btn-nav-phone:hover { background: var(--bg-dark); color: #fff; }

    .btn-nav-book {
      display: inline-flex; align-items: center;
      padding: 0.5rem 1.1rem;
      background: var(--accent); color: #fff;
      border-radius: 50px;
      font-size: 0.85rem; font-weight: 600;
      transition: all 0.2s; white-space: nowrap;
    }
    .btn-nav-book:hover { background: var(--accent-h); transform: translateY(-1px); }

    .nav-phone-mobile { display: none; align-items: center; justify-content: center; width: 40px; height: 40px; background: var(--bg-dark); border-radius: 8px; color: #fff; }
    .nav-hamburger { display: none; align-items: center; justify-content: center; width: 40px; height: 40px; background: transparent; border: 1.5px solid var(--border); border-radius: 8px; cursor: pointer; color: var(--text); }

    @media (max-width: 768px) {
      .nav-inner { display: flex; justify-content: space-between; align-items: center; }
      .nav-links, .btn-nav-phone, .btn-nav-book { display: none; }
      .nav-phone-mobile { display: flex; }
      .nav-hamburger { display: flex; }
    }

    /* HERO */
    .hero { background: var(--bg); padding: 3.5rem 0 3rem; }
    .hero-inner { display: grid; grid-template-columns: 1fr 400px; gap: 4rem; align-items: center; }

    .hero-eyebrow { display: inline-block; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; }

    .hero h1 {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: clamp(2rem, 3.8vw, 3rem);
      font-weight: 600; line-height: 1.15;
      color: var(--text); margin-bottom: 1rem;
    }
    .hero h1 em { font-style: italic; font-weight: 400; }

    .hero-sub { font-size: 0.95rem; color: var(--mid); line-height: 1.75; margin-bottom: 1.25rem; }

    .hero-bullets { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.25rem; }
    .hero-bullets li { display: flex; align-items: center; gap: 0.55rem; font-size: 0.875rem; color: var(--mid); font-weight: 500; }
    .bcheck { width: 18px; height: 18px; background: rgba(28,56,40,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .bcheck svg { width: 9px; height: 9px; }

    /* PLACEHOLDER: replace with real Google review data */
    .hero-reviews {
      display: inline-flex; align-items: center; gap: 0.6rem;
      background: var(--cream); border: 1px solid var(--border);
      border-radius: 50px; padding: 0.45rem 1rem;
      margin-bottom: 1.5rem; font-size: 0.8rem; color: var(--mid);
    }
    .stars { color: #FBBC05; }

    .hero-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }

    .btn-primary {
      display: inline-flex; align-items: center; gap: 0.45rem;
      padding: 0.85rem 1.75rem;
      background: var(--bg-dark); color: #fff;
      border-radius: 50px; font-size: 0.9rem; font-weight: 600;
      box-shadow: 0 4px 14px rgba(28,56,40,0.22);
      transition: all 0.25s;
    }
    .btn-primary:hover { background: #143020; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(28,56,40,0.3); }
    .btn-primary svg { width: 14px; height: 14px; flex-shrink: 0; }

    .btn-secondary {
      display: inline-flex; align-items: center; gap: 0.45rem;
      padding: 0.85rem 1.75rem;
      background: var(--accent); color: #fff;
      border-radius: 50px; font-size: 0.9rem; font-weight: 600;
      box-shadow: 0 4px 14px rgba(196,91,42,0.22);
      transition: all 0.25s;
    }
    .btn-secondary:hover { background: var(--accent-h); transform: translateY(-2px); }
    .btn-secondary svg { width: 14px; height: 14px; flex-shrink: 0; }

    .hero-image-wrap { position: relative; }
    .hero-img-accent {
      position: absolute; top: -1.5rem; right: -1.5rem;
      width: 120px; height: 120px; border-radius: 50%;
      background: var(--accent); opacity: 0.1; z-index: 0;
    }
    .hero-img-main {
      position: relative; z-index: 1;
      width: 100%; aspect-ratio: 3/4;
      border-radius: 200px 200px 32px 32px;
      background: var(--bg-card);
      overflow: hidden;
      box-shadow: 0 18px 42px rgba(28,56,40,0.16);
    }
    .hero-img-main img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      object-position: center;
    }
    .hero-img-badge {
      position: absolute; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
      background: rgba(255,255,255,0.94); border-radius: 50px;
      padding: 0.5rem 1.25rem; display: flex; align-items: center; gap: 0.5rem; white-space: nowrap;
    }
    .hero-img-badge strong { font-size: 0.8rem; font-weight: 700; color: var(--bg-dark); }
    .hero-img-badge span { font-size: 0.72rem; color: var(--mid); }

    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; }
      .hero-image-wrap { display: none; }
      .hero { padding: 2rem 0; }
    }

    /* TRUST BAR */
    .trust-bar { background: var(--bg-dark); padding: 2rem 0; }
    .trust-inner { display: flex; justify-content: center; align-items: center; gap: 0; flex-wrap: wrap; }
    .trust-item { text-align: center; padding: 0.5rem 2.5rem; }
    .trust-item strong { display: block; font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.9rem; font-weight: 600; line-height: 1.1; color: #fff; }
    .trust-item span { font-size: 0.7rem; font-weight: 400; letter-spacing: 0.07em; text-transform: uppercase; color: rgba(255,255,255,0.5); }
    .trust-div { width: 1px; height: 40px; background: rgba(255,255,255,0.12); }
    @media (max-width: 600px) { .trust-div { display: none; } .trust-item { padding: 0.5rem 1.5rem; } }

    /* SECTION HEADERS */
    .section-header { text-align: center; margin-bottom: 3rem; }
    .section-eyebrow { display: block; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; }
    .section-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 600; line-height: 1.2; color: var(--text); }
    .section-title em { font-style: italic; font-weight: 400; }
    .section-sub { font-size: 0.92rem; color: var(--mid); max-width: 500px; margin: 0.75rem auto 0; line-height: 1.7; }

    /* SERVICES */
    .services { padding: 5rem 0; }
    .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
    .service-card {
      background: var(--cream); border: 1px solid var(--border);
      border-radius: 16px; padding: 1.75rem; transition: all 0.25s;
    }
    .service-card:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(28,56,40,0.1); border-color: var(--light); }
    .svc-icon {
      width: 46px; height: 46px;
      background: rgba(28,56,40,0.08); border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      color: var(--bg-dark); margin-bottom: 1rem;
    }
    .svc-icon svg { width: 22px; height: 22px; }
    .service-card h3 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.25rem; font-weight: 600; color: var(--text); margin-bottom: 0.3rem; }
    .svc-duration { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.65rem; }
    .service-card p { font-size: 0.875rem; color: var(--mid); line-height: 1.7; }
    @media (max-width: 768px) { .services-grid { grid-template-columns: 1fr; } }
    @media (min-width: 769px) and (max-width: 960px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }

    /* REVIEWS */
    .reviews { background: var(--bg-card); padding: 5rem 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .reviews-score { display: flex; align-items: center; justify-content: center; gap: 1rem; margin-bottom: 2.75rem; }
    .big-stars { font-size: 1.5rem; color: #FBBC05; }
    .reviews-score-text strong { display: block; font-family: 'Cormorant Garamond', Georgia, serif; font-size: 2rem; font-weight: 600; line-height: 1; }
    .reviews-score-text span { font-size: 0.8rem; color: var(--mid); }
    .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
    .review-card { background: var(--bg); border: 1px solid var(--border); border-radius: 16px; padding: 1.75rem; }
    .review-stars { color: #FBBC05; font-size: 0.9rem; margin-bottom: 0.75rem; }
    .review-card blockquote { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.05rem; font-style: italic; line-height: 1.75; color: var(--text); margin-bottom: 1rem; }
    .review-author { font-size: 0.82rem; font-weight: 600; color: var(--text); }
    .review-location { font-size: 0.75rem; color: var(--mid); }
    @media (max-width: 768px) { .reviews-grid { grid-template-columns: 1fr; } }

    /* ABOUT */
    .about { padding: 5rem 0; }
    .about-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4.5rem; align-items: center; }
    /* PLACEHOLDER: replace with real studio or therapist photo */
    .about-img {
      aspect-ratio: 4/5; border-radius: 200px 200px 32px 32px;
      background: linear-gradient(150deg, #B8CCBE 0%, #4A7060 55%, #1C3828 100%);
    }
    .about h2 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(1.8rem, 3.5vw, 2.5rem); font-weight: 600; line-height: 1.25; color: var(--text); margin-bottom: 1.25rem; }
    .about h2 em { font-style: italic; font-weight: 400; }
    .about-text { font-size: 0.9rem; color: var(--mid); line-height: 1.85; margin-bottom: 0.9rem; }
    .about-features { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 0.65rem; margin-top: 1.75rem; }
    .about-features li { display: flex; align-items: center; gap: 0.5rem; font-size: 0.84rem; font-weight: 500; color: var(--text); }
    .feat-check { width: 20px; height: 20px; background: rgba(28,56,40,0.08); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .feat-check svg { width: 10px; height: 10px; color: var(--bg-dark); }
    @media (max-width: 768px) {
      .about-inner { grid-template-columns: 1fr; gap: 2rem; }
      .about-img { aspect-ratio: 16/9; border-radius: 16px; }
    }

    /* CONTACT */
    .contact { background: var(--bg-card); padding: 5rem 0; border-top: 1px solid var(--border); }
    .contact-inner { display: grid; grid-template-columns: 1fr 1.4fr; gap: 4rem; align-items: start; }
    .contact-info h2 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(1.8rem, 3.5vw, 2.5rem); font-weight: 600; line-height: 1.25; margin-bottom: 1rem; }
    .contact-info h2 em { font-style: italic; font-weight: 400; }
    .contact-info > p { font-size: 0.9rem; color: var(--mid); line-height: 1.75; margin-bottom: 2rem; }
    .contact-details { display: flex; flex-direction: column; gap: 0.85rem; }
    .contact-detail { display: flex; align-items: center; gap: 0.75rem; font-size: 0.875rem; color: var(--mid); }
    .c-icon { width: 36px; height: 36px; background: rgba(28,56,40,0.08); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--bg-dark); flex-shrink: 0; }
    .c-icon svg { width: 16px; height: 16px; }
    .contact-detail a { color: var(--text); font-weight: 600; }
    .contact-detail a:hover { color: var(--accent); }

    .contact-form { background: var(--bg); border: 1px solid var(--border); border-radius: 20px; padding: 2.25rem; }
    .contact-form h3 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.5rem; font-weight: 600; color: var(--text); margin-bottom: 1.5rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
    .form-row .form-group { margin-bottom: 0; }
    label { font-size: 0.75rem; font-weight: 700; color: var(--text); letter-spacing: 0.04em; text-transform: uppercase; }
    input, select, textarea {
      width: 100%; padding: 0.7rem 1rem;
      border: 1.5px solid var(--border); border-radius: 10px;
      background: var(--bg-card); color: var(--text);
      font-family: 'DM Sans', sans-serif; font-size: 0.875rem;
      outline: none; transition: border-color 0.2s;
    }
    input:focus, select:focus, textarea:focus { border-color: var(--bg-dark); }
    textarea { resize: vertical; min-height: 90px; }
    .form-submit {
      width: 100%; padding: 0.9rem;
      background: var(--bg-dark); color: #fff;
      border: none; border-radius: 50px;
      font-family: 'DM Sans', sans-serif; font-size: 0.95rem; font-weight: 600;
      cursor: pointer; margin-top: 0.5rem; transition: all 0.25s;
    }
    .form-submit:hover { background: #143020; transform: translateY(-2px); }
    @media (max-width: 768px) { .contact-inner { grid-template-columns: 1fr; gap: 2rem; } .form-row { grid-template-columns: 1fr; } }

    /* FOOTER */
    footer { background: var(--bg-dark); color: #fff; padding: 3.5rem 0 2rem; }
    .footer-inner { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 3rem; margin-bottom: 2.5rem; }
    .footer-name { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.5rem; font-weight: 600; margin-bottom: 0.2rem; }
    .footer-tag { font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.45; margin-bottom: 0.75rem; }
    .footer-brand p { font-size: 0.85rem; opacity: 0.55; line-height: 1.75; max-width: 280px; }
    .footer-socials { display: flex; gap: 0.5rem; margin-top: 1.25rem; }
    .footer-social { width: 36px; height: 36px; border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.55); cursor: pointer; transition: all 0.2s; }
    .footer-social:hover { border-color: rgba(255,255,255,0.4); color: #fff; }
    .footer-social svg { width: 15px; height: 15px; }
    .footer-col h4 { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.45; margin-bottom: 1rem; }
    .footer-col ul { list-style: none; }
    .footer-col li { font-size: 0.875rem; opacity: 0.65; margin-bottom: 0.5rem; }
    .footer-col a { opacity: 0.65; transition: opacity 0.2s; }
    .footer-col a:hover { opacity: 1; }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 1.5rem; display: flex; justify-content: space-between; font-size: 0.78rem; opacity: 0.4; }
    @media (max-width: 768px) { .footer-inner { grid-template-columns: 1fr; gap: 2rem; } .footer-bottom { flex-direction: column; gap: 0.5rem; } }

    /* WHATSAPP */
    .whatsapp-btn {
      position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9999;
      display: flex; align-items: center; gap: 0.55rem;
      background: #25D366; color: #fff;
      padding: 0.75rem 1.25rem; border-radius: 50px;
      box-shadow: 0 4px 16px rgba(37,211,102,0.35);
      font-size: 0.875rem; font-weight: 600; transition: all 0.25s;
    }
    .whatsapp-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 22px rgba(37,211,102,0.45); }
    .whatsapp-btn svg { width: 22px; height: 22px; flex-shrink: 0; }
    @media (max-width: 480px) { .whatsapp-btn { padding: 0.75rem; border-radius: 50%; } .wa-label { display: none; } }
  </style>
</head>
<body>

  <header>
    <div class="container">
      <nav class="nav-inner">
        <a href="#" class="nav-logo">
          <div class="nav-logo-name">True Health Massage</div>
        </a>

        <ul class="nav-links">
          <li><a href="#services">Treatments</a></li>
          <li><a href="#reviews">Reviews</a></li>
          <li><a href="#about">About</a></li>
          <li><a href="#contact">Contact</a></li>
