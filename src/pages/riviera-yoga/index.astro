---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Riviera Yoga | Yoga &amp; Massage Studio in Paignton</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    :root {
      --bg:       #F5ECCE;
      --bg-card:  #FBF6E2;
      --bg-dark:  #2A1A08;
      --text:     #2A1A08;
      --mid:      #7A5835;
      --light:    #A08058;
      --border:   #E0CFA0;
      --gold:     #B87A18;
      --cream:    #FDFAEF;
    }

    body { font-family: 'DM Sans', system-ui, sans-serif; color: var(--text); background: var(--bg); line-height: 1.6; }
    a { text-decoration: none; color: inherit; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

    /* ─── PROMO BANNER ─── */
    .promo-banner {
      display: none;
      background: var(--bg-dark);
      color: var(--bg);
      text-align: center;
      padding: 0.55rem 1.5rem;
      font-size: 0.82rem;
      font-weight: 500;
      letter-spacing: 0.015em;
    }
    .promo-banner a { color: var(--bg); text-decoration: underline; text-underline-offset: 2px; opacity: 0.8; }
    .promo-banner a:hover { opacity: 1; }
    @media (min-width: 769px) { .promo-banner { display: block; } }

    /* ─── HEADER / NAV ─── */
    header {
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 200;
    }
    .nav-inner {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      height: 68px;
      gap: 1rem;
    }
    .nav-logo { display: flex; align-items: center; flex-shrink: 0; }
    .nav-logo-name {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.45rem;
      font-weight: 600;
      color: var(--text);
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      justify-content: center;
    }
    .nav-links a { font-size: 0.875rem; font-weight: 500; color: var(--mid); letter-spacing: 0.02em; transition: color 0.2s; }
    .nav-links a:hover { color: var(--text); }

    .nav-right { display: flex; align-items: center; gap: 0.6rem; flex-shrink: 0; }

    .nav-socials { display: flex; gap: 0.35rem; }
    .nav-social {
      display: flex; align-items: center; justify-content: center;
      width: 32px; height: 32px;
      border-radius: 8px; border: 1px solid var(--border);
      color: var(--mid); transition: all 0.2s;
    }
    .nav-social:hover { color: var(--text); border-color: var(--mid); }

    .btn-nav-phone {
      display: flex; align-items: center; gap: 0.4rem;
      padding: 0.85rem 2rem;
      border: 1.5px solid var(--border); border-radius: 50px;
      font-size: 0.9rem; font-weight: 600; color: var(--mid);
      transition: all 0.2s; white-space: nowrap;
    }
    .btn-nav-phone:hover { border-color: var(--mid); color: var(--text); }

    .btn-nav-book {
      padding: 0.85rem 2rem;
      background: var(--bg-dark); color: var(--bg);
      border-radius: 50px;
      font-size: 0.9rem; font-weight: 600; letter-spacing: 0.04em;
      transition: all 0.2s; white-space: nowrap;
    }
    .btn-nav-book:hover { background: #4A2E14; transform: translateY(-1px); }

    .nav-phone-mobile {
      display: none;
      align-items: center; justify-content: center;
      width: 40px; height: 40px;
      background: var(--bg-dark); border-radius: 8px;
      color: var(--bg);
    }
    .nav-hamburger {
      display: none;
      align-items: center; justify-content: center;
      width: 40px; height: 40px;
      background: transparent; border: 1.5px solid var(--border);
      border-radius: 8px; cursor: pointer; color: var(--text);
    }

    @media (max-width: 768px) {
      .nav-inner { grid-template-columns: 1fr auto auto; gap: 0.75rem; }
      .nav-links, .nav-socials, .btn-nav-phone, .btn-nav-book { display: none; }
      .nav-phone-mobile { display: flex; }
      .nav-hamburger { display: flex; }
    }

    /* ─── HERO ─── */
    .hero { background: var(--bg); padding: 2.5rem 0 0; text-align: center; overflow: hidden; }

    .hero-eyebrow {
      display: inline-block;
      font-size: 0.72rem; font-weight: 600;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--mid);
      padding: 0.3rem 0.9rem;
      border: 1px solid var(--border); border-radius: 50px;
      margin-bottom: 0.9rem;
    }

    .hero h1 {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: clamp(2.1rem, 5vw, 3.4rem);
      font-weight: 600; line-height: 1.15;
      color: var(--text);
      margin-bottom: 0.9rem;
    }
    .hero h1 em { font-style: italic; font-weight: 400; }

    .hero-sub {
      font-size: clamp(0.9rem, 1.8vw, 1.05rem);
      color: var(--mid); font-weight: 300; line-height: 1.7;
      max-width: 500px; margin: 0 auto 1.1rem;
    }

    .hero-bullets {
      list-style: none;
      display: inline-flex; flex-direction: column; align-items: flex-start;
      gap: 0.35rem; margin-bottom: 1.2rem; text-align: left;
    }
    .hero-bullets li { display: flex; align-items: center; gap: 0.55rem; font-size: 0.875rem; color: var(--mid); font-weight: 500; }
    .hero-bullets .tick { width: 16px; height: 16px; color: var(--gold); flex-shrink: 0; }

    /* Google review widget */
    /* PLACEHOLDER: replace with real Google review data */
    .hero-reviews {
      display: inline-flex; align-items: center; gap: 0.55rem;
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 50px; padding: 0.4rem 1rem;
      margin-bottom: 1rem;
      font-size: 0.8rem; color: var(--mid);
    }
    .stars { color: #FBBC05; letter-spacing: 0.05em; }

    .hero-ctas {
      display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;
      margin-bottom: 2.5rem;
    }

    .btn-primary {
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.85rem 2rem;
      background: var(--bg-dark); color: var(--bg);
      border-radius: 50px; font-size: 0.9rem; font-weight: 600; letter-spacing: 0.04em;
      box-shadow: 0 4px 14px rgba(42,26,8,0.2);
      transition: all 0.25s;
    }
    .btn-primary:hover { background: #4A2E14; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(42,26,8,0.28); }

    .btn-secondary {
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.85rem 2rem;
      background: transparent; color: var(--text);
      border: 1.5px solid var(--border); border-radius: 50px;
      font-size: 0.9rem; font-weight: 600;
      transition: all 0.25s;
    }
    .btn-secondary:hover { border-color: var(--mid); transform: translateY(-2px); }

    /* Hero oval images */
    .hero-images {
      display: flex; justify-content: center; gap: 1rem;
      max-width: 900px; margin: 0 auto; padding: 0 1.5rem;
    }
    .hero-oval {
      flex: 1; max-width: 280px;
      aspect-ratio: 3/4; border-radius: 180px;
      overflow: hidden; position: relative;
    }
    .hero-oval-1 { background: linear-gradient(155deg, #D4B896 0%, #9E7250 100%); }
    .hero-oval-2 { background: linear-gradient(155deg, #C5B5A5 0%, #8A7060 100%); margin-top: -2rem; }
    .hero-oval-3 { background: linear-gradient(155deg, #B8C8A0 0%, #78926A 100%); }
    .hero-oval-label {
      position: absolute; bottom: 1rem; left: 50%; transform: translateX(-50%);
      font-size: 0.65rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
      color: rgba(255,255,255,0.82); white-space: nowrap;
    }

    @media (max-width: 480px) {
      .hero { padding: 1.75rem 0 0; }
      .hero-oval-2 { margin-top: -1rem; }
    }

    /* ─── TRUST BAR ─── */
    .trust-bar { background: var(--bg-dark); padding: 2rem 0; }
    .trust-inner { display: flex; justify-content: center; gap: 3rem; flex-wrap: wrap; }
    .trust-item { text-align: center; }
    .trust-item strong {
      display: block;
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 2rem; font-weight: 600; line-height: 1.1;
      color: var(--bg);
    }
    .trust-item span { font-size: 0.75rem; font-weight: 400; letter-spacing: 0.07em; text-transform: uppercase; color: rgba(245,236,206,0.55); }

    /* ─── SECTION HEADER ─── */
    .section-header { text-align: center; margin-bottom: 3rem; }
    .section-eyebrow { display: block; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mid); margin-bottom: 0.75rem; }
    .section-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 600; line-height: 1.2; color: var(--text); }
    .section-title em { font-style: italic; font-weight: 400; }
    .section-sub { font-size: 0.95rem; color: var(--mid); max-width: 480px; margin: 0.75rem auto 0; font-weight: 300; }

    /* ─── SERVICES ─── */
    .services { padding: 5rem 0; }
    .services-group { margin-bottom: 3.5rem; }
    .services-group-title {
      display: flex; align-items: center; gap: 1rem;
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.3rem; font-weight: 600; color: var(--text);
      margin-bottom: 1.5rem;
    }
    .services-group-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }

    .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }

    .service-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 16px; padding: 1.75rem;
      transition: all 0.25s;
    }
    .service-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(42,26,8,0.1); border-color: var(--mid); }

    .svc-icon {
      width: 44px; height: 44px;
      background: rgba(42,26,8,0.06); border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      color: var(--text); margin-bottom: 1rem;
    }
    .svc-icon svg { width: 20px; height: 20px; }

    .service-card h3 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.2rem; font-weight: 600; color: var(--text); margin-bottom: 0.5rem; }
    .service-card p { font-size: 0.875rem; color: var(--mid); line-height: 1.65; font-weight: 300; }

    @media (max-width: 768px) { .services-grid { grid-template-columns: 1fr; } }
    @media (min-width: 769px) and (max-width: 960px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }

    /* ─── REVIEWS ─── */
    .reviews { background: var(--bg-card); padding: 5rem 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .reviews-score { display: flex; align-items: center; justify-content: center; gap: 0.75rem; margin-bottom: 2.5rem; }
    .big-stars { font-size: 1.4rem; color: #FBBC05; }
    .reviews-score-text strong { display: block; font-family: 'Cormorant Garamond', Georgia, serif; font-size: 2rem; font-weight: 600; }
    .reviews-score-text span { font-size: 0.8rem; color: var(--mid); }
    .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
    .review-card { background: var(--bg); border: 1px solid var(--border); border-radius: 16px; padding: 1.75rem; }
    .review-stars { color: #FBBC05; font-size: 0.85rem; margin-bottom: 0.75rem; }
    .review-card blockquote { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.05rem; font-style: italic; line-height: 1.7; color: var(--text); margin-bottom: 1rem; }
    .review-author { font-size: 0.8rem; font-weight: 600; color: var(--mid); }
    .review-location { font-size: 0.75rem; color: var(--light); font-weight: 300; }
    @media (max-width: 768px) { .reviews-grid { grid-template-columns: 1fr; } }

    /* ─── ABOUT ─── */
    .about { padding: 5rem 0; }
    .about-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
    .about-img {
      aspect-ratio: 4/5;
      border-radius: 180px 180px 16px 16px;
      background: linear-gradient(155deg, #D0BAA0 0%, #8A6A50 100%);
    }
    .about h2 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(1.8rem, 3.5vw, 2.5rem); font-weight: 600; line-height: 1.25; color: var(--text); margin-bottom: 1.25rem; }
    .about h2 em { font-style: italic; font-weight: 400; }
    .about-text { font-size: 0.92rem; color: var(--mid); line-height: 1.8; font-weight: 300; margin-bottom: 0.9rem; }
    .about-features { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; margin-top: 1.5rem; }
    .about-features li { display: flex; align-items: center; gap: 0.5rem; font-size: 0.84rem; font-weight: 500; color: var(--text); }
    .feat-check {
      width: 20px; height: 20px;
      background: rgba(42,26,8,0.07); border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: var(--gold); flex-shrink: 0;
    }
    .feat-check svg { width: 10px; height: 10px; }
    @media (max-width: 768px) {
      .about-inner { grid-template-columns: 1fr; gap: 2rem; }
      .about-img { aspect-ratio: 16/9; border-radius: 16px; }
    }

    /* ─── CONTACT ─── */
    .contact { background: var(--bg-card); padding: 5rem 0; border-top: 1px solid var(--border); }
    .contact-inner { display: grid; grid-template-columns: 1fr 1.4fr; gap: 4rem; align-items: start; }
    .contact-info h2 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(1.8rem, 3.5vw, 2.5rem); font-weight: 600; line-height: 1.25; margin-bottom: 1rem; }
    .contact-info h2 em { font-style: italic; font-weight: 400; }
    .contact-info p { font-size: 0.9rem; color: var(--mid); line-height: 1.7; margin-bottom: 1.75rem; font-weight: 300; }
    .contact-details { display: flex; flex-direction: column; gap: 0.75rem; }
    .contact-detail { display: flex; align-items: center; gap: 0.75rem; font-size: 0.875rem; color: var(--mid); }
    .c-icon {
      width: 36px; height: 36px;
      background: rgba(42,26,8,0.06); border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      color: var(--text); flex-shrink: 0;
    }
    .c-icon svg { width: 16px; height: 16px; }
    .contact-detail a { color: var(--text); font-weight: 500; }
    .contact-detail a:hover { text-decoration: underline; }

    .contact-form { background: var(--bg); border: 1px solid var(--border); border-radius: 20px; padding: 2.25rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
    .form-row .form-group { margin-bottom: 0; }
    label { font-size: 0.78rem; font-weight: 600; color: var(--text); letter-spacing: 0.03em; }
    input, select, textarea {
      width: 100%; padding: 0.7rem 1rem;
      border: 1px solid var(--border); border-radius: 10px;
      background: var(--bg-card); color: var(--text);
      font-family: 'DM Sans', sans-serif; font-size: 0.875rem;
      outline: none; transition: border-color 0.2s;
    }
    input:focus, select:focus, textarea:focus { border-color: var(--mid); }
    textarea { resize: vertical; min-height: 90px; }
    .form-submit {
      width: 100%; padding: 0.9rem;
      background: var(--bg-dark); color: var(--bg);
      border: none; border-radius: 50px;
      font-family: 'DM Sans', sans-serif; font-size: 0.95rem; font-weight: 600; letter-spacing: 0.04em;
      cursor: pointer; margin-top: 0.5rem;
      transition: all 0.25s;
    }
    .form-submit:hover { background: #4A2E14; transform: translateY(-2px); }
    @media (max-width: 768px) { .contact-inner { grid-template-columns: 1fr; gap: 2rem; } .form-row { grid-template-columns: 1fr; } }

    /* ─── FOOTER ─── */
    footer { background: var(--bg-dark); color: var(--bg); padding: 3.5rem 0 2rem; }
    .footer-inner { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 3rem; margin-bottom: 2.5rem; }
    .footer-name { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.5rem; font-weight: 600; margin-bottom: 0.2rem; }
    .footer-tag { font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.45; margin-bottom: 0.75rem; }
    .footer-brand p { font-size: 0.85rem; opacity: 0.55; line-height: 1.7; max-width: 280px; font-weight: 300; }
    .footer-socials { display: flex; gap: 0.5rem; margin-top: 1.25rem; }
    .footer-social {
      width: 36px; height: 36px;
      border: 1px solid rgba(245,236,206,0.18); border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      color: rgba(245,236,206,0.6); cursor: pointer; transition: all 0.2s;
    }
    .footer-social:hover { border-color: rgba(245,236,206,0.45); color: var(--bg); }
    .footer-social svg { width: 15px; height: 15px; }
    .footer-col h4 { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.45; margin-bottom: 1rem; }
    .footer-col ul { list-style: none; }
    .footer-col li { font-size: 0.875rem; opacity: 0.65; margin-bottom: 0.5rem; font-weight: 300; }
    .footer-col a { opacity: 0.65; transition: opacity 0.2s; }
    .footer-col a:hover { opacity: 1; }
    .footer-bottom { border-top: 1px solid rgba(245,236,206,0.1); padding-top: 1.5rem; display: flex; justify-content: space-between; font-size: 0.78rem; opacity: 0.4; }
    @media (max-width: 768px) { .footer-inner { grid-template-columns: 1fr; gap: 2rem; } .footer-bottom { flex-direction: column; gap: 0.5rem; } }

    /* ─── WHATSAPP ─── */
    .whatsapp-btn {
      position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9999;
      display: flex; align-items: center; gap: 0.55rem;
      background: #25D366; color: #fff;
      padding: 0.75rem 1.25rem; border-radius: 50px;
      box-shadow: 0 4px 16px rgba(37,211,102,0.35);
      font-size: 0.875rem; font-weight: 600;
      transition: all 0.25s;
    }
    .whatsapp-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 22px rgba(37,211,102,0.45); }
    .whatsapp-btn svg { width: 22px; height: 22px; flex-shrink: 0; }
    @media (max-width: 480px) { .whatsapp-btn { padding: 0.75rem; border-radius: 50%; } .wa-label { display: none; } }
  </style>
</head>
<body>

  <!-- PROMO BANNER — desktop only -->
  <div class="promo-banner">
    June Offer: 20% off all class passes this month. No code needed.
    <a href="#contact">Book now to claim your discount.</a>
  </div>

  <!-- HEADER -->
  <header>
    <div class="container">
      <nav class="nav-inner">
        <a href="#" class="nav-logo">
          <span class="nav-logo-name">Riviera Yoga</span>
        </a>

        <ul class="nav-links">
          <li><a href="#services">Classes</a></li>
          <li><a href="#treatments">Treatments</a></li>
          <li><a href="#reviews">Reviews</a></li>
          <li><a href="#about">About</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>

        <div class="nav-right">
          <div class="nav-socials">
            <a href="#" class="nav-social" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
              </svg>
            </a>
            <a href="#" class="nav-social" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          </div>

          <a href="tel:01803456789" class="btn-nav-phone">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.91-1.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.5 15.28z"/>
            </svg>
            01803 456789
          </a>

          <a href="#contact" class="btn-nav-book">Book Now</a>

