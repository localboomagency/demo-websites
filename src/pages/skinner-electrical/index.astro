---
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Skinner Electrical | Electricians in Plymouth</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:         #0a0a0a;
      --surface:    #131313;
      --surface-2:  #1b1b1b;
      --border:     #252525;
      --gold:       #F5C400;
      --gold-hover: #ddb000;
      --gold-dim:   rgba(245,196,0,0.10);
      --white:      #ffffff;
      --text:       #cccccc;
      --muted:      #777777;
      --radius:     6px;
      --nav-h:      70px;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', system-ui, sans-serif;
      line-height: 1.6;
      font-size: 1rem;
    }

    h1, h2 {
      font-family: 'Bebas Neue', Impact, 'Arial Black', sans-serif;
      line-height: 1;
      color: var(--white);
      letter-spacing: 0.02em;
    }

    a { text-decoration: none; color: inherit; }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* ─── NAV ─── */
    nav {
      background: #0d0d0d;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 200;
    }

    .nav-inner {
      display: grid;
      grid-template-columns: auto 1fr auto auto auto;
      align-items: center;
      gap: 1rem;
      height: var(--nav-h);
    }

    .nav-logo img {
      height: 52px;
      width: auto;
      display: block;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      justify-self: center;
    }

    .nav-links a {
      color: var(--text);
      font-size: 0.8125rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--gold); }

    .nav-email {
      display: inline-block;
      background: transparent;
      color: var(--white);
      padding: 0.875rem 1.5rem;
      border-radius: var(--radius);
      border: 1.5px solid rgba(255,255,255,0.2);
      font-weight: 600;
      font-size: 1rem;
      white-space: nowrap;
      transition: border-color 0.2s, color 0.2s;
    }

    .nav-email:hover { border-color: var(--gold); color: var(--gold); }

    .nav-phone {
      background: var(--gold);
      color: #000;
      padding: 0.875rem 1.75rem;
      border-radius: var(--radius);
      font-weight: 700;
      font-size: 1rem;
      white-space: nowrap;
      transition: background 0.2s;
    }

    .nav-phone:hover { background: var(--gold-hover); }

    .nav-hamburger {
      display: none;
      align-items: center;
      justify-content: center;
      background: none;
      border: 1px solid var(--border);
      color: var(--white);
      width: 40px;
      height: 40px;
      border-radius: var(--radius);
      cursor: pointer;
    }

    /* ─── HERO ─── */
    .hero {
      position: relative;
      overflow: hidden;
      background: var(--bg);
      padding: 3rem 0 2.5rem;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 35% 50%, rgba(245,196,0,0.05) 0%, transparent 65%);
      pointer-events: none;
    }

    .hero-bolt {
      position: absolute;
      left: 2%;
      top: 50%;
      transform: translateY(-50%);
      width: 42%;
      max-width: 480px;
      opacity: 0.08;
      pointer-events: none;
      user-select: none;
    }

    .hero-inner {
      position: relative;
      z-index: 2;
      max-width: 680px;
    }

    /* Google review pill */
    .hero-google {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 50px;
      padding: 0.375rem 1rem 0.375rem 0.625rem;
      margin-bottom: 1rem;
    }

    .stars-row { display: flex; gap: 1px; }
    .star { color: var(--gold); font-size: 0.875rem; line-height: 1; }

    .google-pill-text {
      font-size: 0.8125rem;
      color: var(--text);
    }

    .google-pill-text strong { color: var(--white); }

    /* H1 */
    .hero h1 {
      font-size: clamp(3.25rem, 7vw, 5rem);
      margin-bottom: 0.875rem;
    }

    .hero h1 .highlight { color: var(--gold); }

    .hero-sub {
      font-size: 1.0625rem;
      color: var(--text);
      max-width: 540px;
      line-height: 1.65;
      margin-bottom: 1.25rem;
    }

    .hero-sub-mobile {
      display: none;
      font-size: 1.0625rem;
      color: var(--text);
      line-height: 1.65;
      margin-bottom: 1.25rem;
    }

    /* Bullets */
    .hero-bullets {
      list-style: none;
      margin-bottom: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .hero-bullets li {
      font-size: 0.9375rem;
      color: var(--text);
      padding-left: 1rem;
      border-left: 3px solid var(--gold);
    }

    /* CTAs */
    .hero-ctas {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    /* ─── HERO GALLERY ─── */
    .hero-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
    }

    .hero-gallery {
      position: relative;
      height: 460px;
    }

    .gallery-img {
      position: absolute;
      border-radius: 10px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .gallery-img img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
    }

    .gallery-img-1 {
      top: 0; left: 0; right: 18%; bottom: 34%;
      z-index: 1;
      border: 1px solid var(--border);
      background:
        repeating-linear-gradient(-45deg, transparent, transparent 14px, rgba(245,196,0,0.04) 14px, rgba(245,196,0,0.04) 15px),
        linear-gradient(160deg, #1e1e1e 0%, #111 100%);
    }

    .gallery-img-2 {
      top: 40%; left: 18%; right: 0; bottom: 0;
      z-index: 2;
      border: 2px solid var(--gold);
      background:
        repeating-linear-gradient(-45deg, transparent, transparent 14px, rgba(245,196,0,0.04) 14px, rgba(245,196,0,0.04) 15px),
        linear-gradient(160deg, #1c1c1c 0%, #141414 100%);
    }

    .btn-primary {
      display: inline-block;
      background: var(--gold);
      color: #000;
      padding: 0.875rem 2rem;
      border-radius: var(--radius);
      font-weight: 700;
      font-size: 1rem;
      transition: background 0.2s, transform 0.15s;
    }

    .btn-primary:hover {
      background: var(--gold-hover);
      transform: translateY(-1px);
    }

    .btn-secondary {
      display: inline-block;
      background: transparent;
      color: var(--white);
      padding: 0.875rem 2rem;
      border-radius: var(--radius);
      border: 1.5px solid rgba(255,255,255,0.25);
      font-weight: 600;
      font-size: 1rem;
      transition: border-color 0.2s, color 0.2s, transform 0.15s;
    }

    .btn-secondary:hover {
      border-color: var(--gold);
      color: var(--gold);
      transform: translateY(-1px);
    }

    /* ─── TRUST BAR ─── */
    .trust-bar {
      background: var(--gold);
      padding: 1.5rem 0;
    }

    .trust-bar-inner {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      text-align: center;
    }

    .trust-item { display: flex; flex-direction: column; align-items: center; gap: 0.1rem; }

    .trust-number {
      font-family: 'Bebas Neue', Impact, sans-serif;
      font-size: 2.5rem;
      line-height: 1;
      color: #000;
      letter-spacing: 0.02em;
    }

    .trust-label {
      font-size: 0.6875rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(0,0,0,0.55);
    }

    /* ─── SHARED SECTION HEADER ─── */
    .section-label {
      font-size: 0.6875rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--gold);
      margin-bottom: 0.6rem;
    }

    .section-title {
      font-size: clamp(2.25rem, 5vw, 3.25rem);
      color: var(--white);
      margin-bottom: 0.75rem;
    }

    .section-sub {
      font-size: 1.0625rem;
      color: var(--muted);
      max-width: 520px;
      line-height: 1.65;
      margin-bottom: 3rem;
    }

    /* ─── SERVICES ─── */
    .services {
      padding: 5rem 0;
      background: var(--bg);
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .service-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-top: 3px solid var(--gold);
      border-radius: var(--radius);
      padding: 2rem 1.75rem;
    }

    .service-num {
      font-family: 'Bebas Neue', Impact, sans-serif;
      font-size: 0.875rem;
      letter-spacing: 0.12em;
      color: var(--gold);
      margin-bottom: 0.75rem;
    }

    .service-name {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--white);
      line-height: 1.3;
      margin-bottom: 0.625rem;
    }

    .service-desc {
      font-size: 0.875rem;
      color: var(--muted);
      line-height: 1.65;
    }

    /* ─── REVIEWS ─── */
    .reviews {
      padding: 5rem 0;
      background: var(--surface);
    }

    .reviews-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .reviews-score {
      display: inline-flex;
      align-items: center;
      gap: 0.875rem;
      margin-bottom: 0.875rem;
    }

    .score-num {
      font-family: 'Bebas Neue', Impact, sans-serif;
      font-size: 4rem;
      color: var(--gold);
      line-height: 1;
    }

    .score-detail { display: flex; flex-direction: column; gap: 3px; }
    .score-detail .stars-row .star { font-size: 1.25rem; }
    .score-count { font-size: 0.875rem; color: var(--muted); }

    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .review-card {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.75rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .review-stars .star { font-size: 0.9375rem; }

    .review-quote {
      font-size: 0.9375rem;
      color: var(--text);
      line-height: 1.7;
      font-style: italic;
      flex: 1;
    }

    .review-author strong {
      display: block;
      color: var(--white);
      font-size: 0.875rem;
      font-weight: 600;
    }

    .review-author span {
      font-size: 0.8125rem;
      color: var(--muted);
    }

    /* ─── ABOUT ─── */
    .about {
      padding: 5rem 0;
      background: var(--bg);
    }

    .about-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }

    .about-body {
      font-size: 1rem;
      color: var(--text);
      line-height: 1.75;
      margin-bottom: 1.25rem;
    }

    .about-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
      margin-top: 2.25rem;
    }

    .about-stat {
      border-left: 3px solid var(--gold);
      padding-left: 1rem;
    }

    .about-stat-num {
      font-family: 'Bebas Neue', Impact, sans-serif;
      font-size: 2rem;
      color: var(--gold);
      line-height: 1;
    }

    .about-stat-label {
      font-size: 0.8125rem;
      color: var(--muted);
      margin-top: 0.2rem;
    }

    .accred-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2rem 2rem 2.25rem;
    }

    .accred-heading {
      font-size: 0.6875rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--gold);
      margin-bottom: 1.5rem;
    }

    .accred-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
    }

    .accred-list li {
      font-size: 0.9375rem;
      color: var(--text);
      padding-left: 1rem;
      border-left: 2px solid var(--border);
    }

    /* ─── CONTACT ─── */
    .contact {
      padding: 5rem 0;
      background: var(--surface);
    }

    .contact-inner {
      display: grid;
      grid-template-columns: 1fr 1.5fr;
      gap: 5rem;
      align-items: start;
    }

    .contact-details {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      margin-top: 2rem;
    }

    .contact-row { display: flex; flex-direction: column; gap: 0.125rem; }

    .contact-row-label {
      font-size: 0.6875rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--gold);
    }

    .contact-row-value {
      font-size: 0.9375rem;
      color: var(--text);
    }

    .contact-form {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2.5rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .form-group { margin-bottom: 1.125rem; }

    .form-group label {
      display: block;
      font-size: 0.8125rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.375rem;
    }

    .form-group input,
    .form-group textarea {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      color: var(--white);
      padding: 0.75rem 1rem;
      font-size: 0.9375rem;
      font-family: inherit;
      outline: none;
      transition: border-color 0.2s;
    }

    .form-group input::placeholder,
    .form-group textarea::placeholder { color: var(--muted); }

    .form-group input:focus,
    .form-group textarea:focus { border-color: var(--gold); }

    .form-group textarea { resize: vertical; min-height: 120px; }

    .form-submit {
      width: 100%;
      background: var(--gold);
      color: #000;
      border: none;
      border-radius: var(--radius);
      padding: 0.875rem 2rem;
      font-size: 1rem;
      font-weight: 700;
      font-family: inherit;
      cursor: pointer;
      transition: background 0.2s;
    }

    .form-submit:hover { background: var(--gold-hover); }

    /* ─── FOOTER ─── */
    footer {
      background: #060606;
      border-top: 1px solid var(--border);
      padding: 3.5rem 0 2rem;
    }

    .footer-inner {
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 3rem;
      margin-bottom: 2.5rem;
    }

    .footer-brand img {
      height: 40px;
      width: auto;
      display: block;
      margin-bottom: 1rem;
    }

    .footer-brand-desc {
      font-size: 0.875rem;
      color: var(--muted);
      line-height: 1.65;
      margin-bottom: 1.25rem;
    }

    .footer-social { display: flex; gap: 0.625rem; }

    .social-chip {
      width: 34px;
      height: 34px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--muted);
      cursor: default;
      transition: color 0.2s, border-color 0.2s;
    }

    .social-chip:hover { color: var(--gold); border-color: var(--gold); }

    .footer-col-title {
      font-size: 0.6875rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--gold);
      margin-bottom: 1rem;
    }

    .footer-col-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .footer-col-list li {
      font-size: 0.875rem;
      color: var(--muted);
    }

    .footer-bottom {
      border-top: 1px solid var(--border);
      padding-top: 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .footer-bottom p {
      font-size: 0.8125rem;
      color: var(--muted);
    }

    /* ─── WHATSAPP ─── */
    .whatsapp-btn {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 9999;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: #25D366;
      color: #fff;
      padding: 0.75rem 1.25rem;
      border-radius: 50px;
      font-weight: 700;
      font-size: 0.875rem;
      box-shadow: 0 4px 18px rgba(37,211,102,0.35);
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .whatsapp-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 22px rgba(37,211,102,0.45);
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 1024px) {
      .hero-grid { gap: 2rem; }
      .hero-gallery { height: 400px; }
      .services-grid { grid-template-columns: repeat(2, 1fr); }
      .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
      .about-inner { gap: 3rem; }
      .contact-inner { gap: 3rem; }
    }

    @media (max-width: 768px) {
      :root { --nav-h: 60px; }

      .nav-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
      }

      .nav-links { display: none; }
      .nav-hamburger { display: flex; }

      .nav-email { display: none; }

      .nav-phone {
        padding: 0.5rem 0.875rem;
        font-size: 0.8rem;
      }

      .hero { padding: 1.75rem 0 2rem; }
      .hero-sub { display: none; }
      .hero-sub-mobile { display: block; }
      .hero-grid { grid-template-columns: 1fr; }
      .hero-gallery { display: none; }

      .trust-bar-inner { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }

      .services-grid { grid-template-columns: 1fr; }
      .reviews-grid { grid-template-columns: 1fr; }
      .about-inner { grid-template-columns: 1fr; gap: 2.5rem; }
      .contact-inner { grid-template-columns: 1fr; gap: 2.5rem; }

      .footer-inner { grid-template-columns: 1fr; gap: 2rem; }
      .footer-bottom { flex-direction: column; align-items: flex-start; }

      .form-row { grid-template-columns: 1fr; }
    }

    @media (max-width: 480px) {
      .whatsapp-btn { padding: 0.75rem; border-radius: 50%; }
      .whatsapp-btn span { display: none; }
    }

    /* ─── VAN BANNER ─── */
    .van-banner {
      display: none;
      position: relative;
      width: 100%;
      line-height: 0;
    }

    .van-banner img {
      width: 100%;
      height: auto;
      display: block;
    }

    .van-banner .hero-google {
      position: absolute;
      bottom: 0.875rem;
      left: 0.875rem;
      display: none;
      margin-bottom: 0;
    }

    @media (max-width: 768px) {
      .van-banner { display: block; }
      .van-banner .hero-google { display: inline-flex; }
      .hero-inner .hero-google { display: none; }
    }
  </style>
</head>

<body>

  <!-- 1. NAV -->
  <nav>
    <div class="container nav-inner">
      <a href="#" class="nav-logo">
        <img src="/skinner-electrical-logo.svg" alt="Skinner Electrical" />
      </a>
      <div class="nav-links">
        <a href="#services">Services</a>
        <a href="#reviews">Reviews</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
      </div>
      <a href="mailto:info@skinnerelectrical.co.uk" class="nav-email">Email Us</a>
      <a href="tel:01752340810" class="nav-phone">01752 340 810 &middot; 24/7</a>
      <button class="nav-hamburger" aria-label="Open menu">
        <svg width="20" height="14" viewBox="0 0 20 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="0" y1="1" x2="20" y2="1"/>
          <line x1="0" y1="7" x2="20" y2="7"/>
          <line x1="0" y1="13" x2="20" y2="13"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- VAN BANNER — mobile only, sits flush under nav -->
  <div class="van-banner">
    <img src="/images/skinner-electrical/signwritten-van.png" alt="Skinner Electrical signwritten van" loading="eager" />
    <!-- PLACEHOLDER: replace with real Google review data -->
    <div class="hero-google">
