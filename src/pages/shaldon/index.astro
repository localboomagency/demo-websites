---
// Shaldon Village, Devon — Local & Visitor Information
// Demo site
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shaldon Village, Devon | Visitor &amp; Local Information</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream:         #FAF6EF;
      --cream-mid:     #F2EDE3;
      --cream-dark:    #E4DDD2;
      --blue:          #7BBDD4;
      --blue-mid:      #5AAEC8;
      --blue-dark:     #3D8FAE;
      --blue-light:    #D4EBF5;
      --blue-xlight:   #EDF6FA;
      --navy:          #1D3A4A;
      --text:          #2A2A2A;
      --text-mid:      #5A5A5A;
      --text-light:    #909090;
      --white:         #fff;
      --shadow-sm:     0 2px 8px rgba(0,0,0,0.06);
      --shadow:        0 4px 18px rgba(0,0,0,0.09);
      --shadow-md:     0 8px 30px rgba(0,0,0,0.13);
      --radius:        10px;
      --radius-lg:     16px;
    }

    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; color: var(--text); background: var(--cream); line-height: 1.6; }
    img { display: block; max-width: 100%; }
    a { color: inherit; }
    ul { list-style: none; }
    button { cursor: pointer; font-family: inherit; border: none; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

    /* ===================== HEADER ===================== */
    .site-header {
      position: sticky; top: 0; z-index: 200;
      background: rgba(255,255,255,0.97);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--cream-dark);
      box-shadow: 0 1px 0 var(--cream-dark);
    }

    .header-top { padding: 0.8rem 0; border-bottom: 1px solid var(--cream-mid); }
    .header-top .container { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; }

    .nav-logo { display: flex; flex-direction: column; line-height: 1.15; flex-shrink: 0; text-decoration: none; }
    .logo-main { font-family: 'Cormorant Garamond', serif; font-size: 1.65rem; font-weight: 600; letter-spacing: 0.04em; color: var(--navy); }
    .logo-sub  { font-size: 0.625rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--blue-mid); }

    .header-top-right { display: flex; align-items: center; gap: 0.625rem; }

    .header-socials { display: flex; align-items: center; gap: 0.25rem; }
    .header-social {
      width: 30px; height: 30px;
      display: flex; align-items: center; justify-content: center;
      color: var(--text-light); border-radius: 6px;
      text-decoration: none; transition: color 0.2s, background 0.2s;
    }
    .header-social:hover { color: var(--navy); background: var(--cream-mid); }

    .header-divider { width: 1px; height: 22px; background: var(--cream-dark); flex-shrink: 0; }

    .header-util-btn {
      display: inline-flex; align-items: center; gap: 0.35rem;
      padding: 0.38rem 0.75rem;
      background: var(--blue-xlight); border: 1.5px solid var(--blue-light);
      border-radius: 50px; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.02em;
      color: var(--navy); text-decoration: none; white-space: nowrap;
      transition: background 0.2s, border-color 0.2s;
      flex-shrink: 0;
    }
    .header-util-btn:hover { background: var(--blue-light); border-color: var(--blue); }

    .search-form {
      display: flex; align-items: center;
      background: var(--cream); border: 1.5px solid var(--cream-dark);
      border-radius: 50px; overflow: hidden;
      transition: border-color 0.2s;
    }
    .search-form:focus-within { border-color: var(--blue); }
    .search-form input {
      border: none; background: transparent;
      padding: 0.45rem 0.875rem; font-size: 0.875rem; font-family: inherit;
      color: var(--text); outline: none; width: 220px;
    }
    .search-form input::placeholder { color: var(--text-light); }
    .search-form button {
      background: transparent; padding: 0.45rem 0.75rem 0.45rem 0.25rem;
      color: var(--text-mid); display: flex; align-items: center;
      transition: color 0.2s;
    }
    .search-form button:hover { color: var(--blue-mid); }

    .nav-hamburger {
      display: none; flex-direction: column; justify-content: center; align-items: center; gap: 4px;
      width: 40px; height: 40px;
      background: transparent; border: 1.5px solid var(--cream-dark) !important;
      border-radius: 8px; flex-shrink: 0;
    }
    .nav-hamburger span { display: block; width: 18px; height: 2px; background: var(--text); border-radius: 2px; }

    .header-bottom { }
    .header-bottom .container { display: flex; align-items: stretch; }

    .nav-links { display: flex; align-items: center; }
    .nav-links li a {
      display: block; padding: 0.65rem 0.65rem;
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;
      color: var(--text-mid); text-decoration: none; white-space: nowrap;
      border-bottom: 2px solid transparent;
      transition: color 0.2s, border-color 0.2s;
    }
    .nav-links li a:hover { color: var(--navy); border-bottom-color: var(--blue); }

    /* ===================== HERO ===================== */
    .hero {
      position: relative; min-height: 100svh; min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      text-align: center; color: var(--white); overflow: hidden;
      background-image: url('/images/shaldon/shaldon.jpg');
      background-size: cover; background-position: center;
    }

    .hero-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to bottom, rgba(10,28,42,0.38) 0%, rgba(10,28,42,0.52) 55%, rgba(10,28,42,0.72) 100%);
    }

    .hero-content {
      position: relative; z-index: 1;
      max-width: 820px; margin: 0 auto;
      padding: 4rem 1.5rem 6rem;
    }

    .hero-badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.35rem 1rem; margin-bottom: 1.75rem;
      background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.22);
      border-radius: 50px;
      font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
    }

    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3.2rem, 8vw, 6rem);
      font-weight: 500; line-height: 1.0;
      margin-bottom: 1rem;
      text-shadow: 0 2px 24px rgba(0,0,0,0.3);
      letter-spacing: 0.01em;
    }

    .hero-tagline {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.1rem, 2.5vw, 1.4rem);
      font-weight: 400; font-style: italic;
      color: rgba(255,255,255,0.85);
      margin-bottom: 2.75rem;
      letter-spacing: 0.01em;
    }

    .hero-search { max-width: 580px; margin: 0 auto 2.5rem; }

    .hero-search-form {
      display: flex; align-items: center;
      background: rgba(255,255,255,0.96);
      border-radius: 50px; overflow: hidden;
      box-shadow: 0 6px 32px rgba(0,0,0,0.28);
    }

    .hero-search-icon {
      flex-shrink: 0; padding: 0 0 0 1.25rem; color: var(--text-light);
      display: flex; align-items: center;
    }

    .hero-search-form input {
      flex: 1; border: none; background: transparent;
      padding: 1rem 0.875rem; font-size: 1rem; font-family: inherit;
      color: var(--text); outline: none;
    }
    .hero-search-form input::placeholder { color: var(--text-light); }

    .hero-search-form button {
      background: var(--blue); color: white;
      padding: 0.875rem 1.625rem;
      font-size: 0.875rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
      border-radius: 0 50px 50px 0;
      transition: background 0.2s;
      flex-shrink: 0;
    }
    .hero-search-form button:hover { background: var(--blue-mid); }

    .hero-quick-links { display: flex; gap: 0.625rem; flex-wrap: wrap; justify-content: center; }

    .hero-quick-link {
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.55rem 1.125rem;
      background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.28);
      border-radius: 50px;
      font-size: 0.8rem; font-weight: 500; letter-spacing: 0.03em;
      text-decoration: none; color: white;
      transition: background 0.2s, border-color 0.2s;
    }
    .hero-quick-link:hover { background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.5); }

    .hero-scroll {
      position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 0.35rem;
      color: rgba(255,255,255,0.5); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase;
      animation: bob 2s ease-in-out infinite;
    }

    @keyframes bob { 0%, 100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(5px); } }

    /* ===================== SECTION COMMON ===================== */
    .section       { padding: 5.5rem 0; }
    .section-alt   { background: var(--blue-xlight); }
    .section-cream { background: var(--cream-mid); }

    .section-header { text-align: center; margin-bottom: 3.25rem; }

    .section-label {
      display: inline-block;
      font-size: 0.65rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--blue-mid); margin-bottom: 0.5rem;
    }

    .section-header h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 4vw, 2.875rem); font-weight: 500; color: var(--navy); line-height: 1.2;
    }

    .section-header p {
      margin-top: 0.75rem; color: var(--text-mid); font-size: 1rem;
      max-width: 560px; margin-inline: auto; line-height: 1.7;
    }

    /* ===================== WELCOME ===================== */
    .welcome-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4.5rem; align-items: center; }

    .welcome-text h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 3.5vw, 2.625rem); font-weight: 500; color: var(--navy);
      margin-bottom: 1.25rem; line-height: 1.2;
    }
    .welcome-text p { color: var(--text-mid); line-height: 1.8; margin-bottom: 1rem; }
    .welcome-text p:last-child { margin-bottom: 0; }

    .welcome-highlights { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

    .highlight-item {
      display: flex; flex-direction: column;
      padding: 1.375rem; border-radius: var(--radius);
      background: var(--white); border: 1px solid var(--cream-dark);
      box-shadow: var(--shadow-sm);
    }

    .highlight-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.25rem; font-weight: 600; color: var(--navy); line-height: 1;
    }

    .highlight-label { font-size: 0.78rem; color: var(--text-mid); margin-top: 0.3rem; line-height: 1.4; }

    /* ===================== CARDS ===================== */
    .cards-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }

    .card {
      background: var(--white); border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm); overflow: hidden;
      border: 1px solid var(--cream-dark);
      transition: transform 0.25s, box-shadow 0.25s;
    }
    .card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }

    .card-image {
      height: 190px;
      background: linear-gradient(135deg, var(--cream-mid) 0%, var(--cream-dark) 100%);
      display: flex; align-items: center; justify-content: center;
      color: var(--cream-dark);
    }

    .card-body { padding: 1.375rem 1.5rem 1.625rem; }

    .card-badge {
      display: inline-block; padding: 0.2rem 0.625rem; margin-bottom: 0.625rem;
      background: var(--blue-light); color: var(--navy);
      border-radius: 50px; font-size: 0.675rem; font-weight: 600;
      letter-spacing: 0.05em; text-transform: uppercase;
    }

    .card h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.35rem; font-weight: 500; color: var(--navy);
      margin-bottom: 0.5rem; line-height: 1.25;
    }

    .card p { font-size: 0.875rem; color: var(--text-mid); line-height: 1.65; }

    .card-link {
      display: inline-flex; align-items: center; gap: 0.3rem; margin-top: 1rem;
      font-size: 0.8rem; font-weight: 600; color: var(--blue-mid);
      text-decoration: none; letter-spacing: 0.02em;
      transition: color 0.2s;
    }
    .card-link:hover { color: var(--navy); }

    /* ===================== EVENTS ===================== */
    .events-list { display: flex; flex-direction: column; gap: 0.875rem; }

    .event-item {
      display: flex; align-items: flex-start; gap: 1.5rem;
      background: var(--white); padding: 1.5rem;
      border-radius: var(--radius); border: 1px solid var(--cream-dark);
      box-shadow: var(--shadow-sm);
      transition: box-shadow 0.2s, border-color 0.2s;
    }
    .event-item:hover { box-shadow: var(--shadow); border-color: var(--blue-light); }

    .event-date {
      flex-shrink: 0; width: 60px; height: 60px;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      background: var(--navy); color: white; border-radius: var(--radius); text-align: center;
    }
    .event-date .day   { font-size: 1.5rem; font-weight: 700; line-height: 1; }
    .event-date .month { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; margin-top: 0.1rem; }

    .event-info { flex: 1; }
    .event-info h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.25rem; font-weight: 500; color: var(--navy); margin-bottom: 0.3rem;
    }
    .event-info p { font-size: 0.875rem; color: var(--text-mid); line-height: 1.6; }

    .event-tag {
      display: inline-block; padding: 0.15rem 0.5rem; margin-top: 0.4rem;
      background: var(--blue-light); color: var(--navy);
      border-radius: 50px; font-size: 0.625rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.06em;
    }

    /* ===================== ACTIVITIES ===================== */
    .activities-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }

    .activity-card {
      display: flex; flex-direction: column; align-items: center; text-align: center;
      padding: 2rem 1.25rem;
      background: var(--white); border-radius: var(--radius-lg);
      border: 1px solid var(--cream-dark); box-shadow: var(--shadow-sm);
      transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
    }
    .activity-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); border-color: var(--blue-light); }

    .activity-icon {
      width: 58px; height: 58px;
      background: var(--blue-xlight); border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1rem; color: var(--blue-mid);
    }

    .activity-card h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.125rem; font-weight: 500; color: var(--navy); margin-bottom: 0.4rem;
    }

    .activity-card p { font-size: 0.8rem; color: var(--text-mid); line-height: 1.55; }

    /* ===================== PARISH COUNCIL ===================== */
    .parish-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 3.5rem; align-items: start; }

    .parish-label { display: block; margin-bottom: 0.5rem; }

    .parish-text h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 3.5vw, 2.5rem); font-weight: 500; color: var(--navy);
      margin-bottom: 1.125rem;
    }

    .parish-text p { color: var(--text-mid); line-height: 1.8; margin-bottom: 1rem; }

    .parish-links { display: flex; flex-direction: column; gap: 0.625rem; margin-top: 1.5rem; }

    .parish-link {
      display: flex; align-items: center; gap: 0.625rem;
      padding: 0.75rem 1rem;
      background: var(--white); border: 1px solid var(--cream-dark);
      border-radius: var(--radius); box-shadow: var(--shadow-sm);
      text-decoration: none; color: var(--navy);
      font-size: 0.875rem; font-weight: 500;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .parish-link:hover { border-color: var(--blue); box-shadow: var(--shadow); }
    .parish-link svg { color: var(--blue-mid); flex-shrink: 0; }

    .parish-meetings {
      background: var(--navy); border-radius: var(--radius-lg);
      padding: 2rem; color: white;
    }

    .parish-meetings h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.375rem; font-weight: 500; margin-bottom: 1.375rem;
    }

    .meeting-item {
      display: flex; justify-content: space-between; align-items: center;
      padding: 0.625rem 0; border-bottom: 1px solid rgba(255,255,255,0.1);
      font-size: 0.8125rem;
    }
    .meeting-item:last-of-type { border-bottom: none; }
    .meeting-item .time { color: rgba(255,255,255,0.55); font-size: 0.75rem; }

    .meeting-note { font-size: 0.72rem; color: rgba(255,255,255,0.38); margin-top: 1.25rem; line-height: 1.5; }

    /* ===================== DIRECTORY ===================== */
    .directory-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }

    .dir-category {
      display: flex; flex-direction: column; align-items: center; text-align: center;
      padding: 1.75rem 1rem;
      background: var(--white); border-radius: var(--radius-lg);
      border: 1px solid var(--cream-dark); box-shadow: var(--shadow-sm);
      text-decoration: none; color: var(--text); cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    }
    .dir-category:hover { transform: translateY(-2px); box-shadow: var(--shadow); border-color: var(--blue); }

    .dir-icon {
      width: 52px; height: 52px;
      background: var(--blue-xlight); border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 0.875rem; color: var(--blue-mid);
    }

    .dir-category h3 { font-size: 0.875rem; font-weight: 600; color: var(--navy); margin-bottom: 0.25rem; }
    .dir-category p { font-size: 0.75rem; color: var(--text-light); }

    /* ===================== CONTACT ===================== */
    .contact-grid { display: grid; grid-template-columns: 1fr 1.6fr; gap: 4rem; }

    .contact-info-col .section-label { margin-bottom: 0.5rem; }

    .contact-info-col h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 3.5vw, 2.5rem); font-weight: 500; color: var(--navy);
      margin-bottom: 1rem;
    }

    .contact-info-col > p { color: var(--text-mid); line-height: 1.8; margin-bottom: 2rem; }

    .contact-details { display: flex; flex-direction: column; gap: 0.875rem; }

    .contact-detail { display: flex; align-items: flex-start; gap: 0.75rem; font-size: 0.875rem; color: var(--text-mid); }

    .detail-icon {
      width: 38px; height: 38px; flex-shrink: 0;
      background: var(--blue-xlight); border-radius: 9px;
      display: flex; align-items: center; justify-content: center; color: var(--blue-mid);
    }

    .contact-form-wrap {
      background: var(--white); padding: 2.5rem;
      border-radius: var(--radius-lg); border: 1px solid var(--cream-dark); box-shadow: var(--shadow);
    }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-full { grid-column: 1 / -1; }

    .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
    .form-group label {
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em;
      text-transform: uppercase; color: var(--text-mid);
    }

    .form-group input,
    .form-group textarea,
    .form-group select {
      border: 1.5px solid var(--cream-dark); border-radius: 8px;
      padding: 0.75rem 1rem; font-size: 0.9375rem; font-family: inherit;
      color: var(--text); background: var(--cream); outline: none;
      transition: border-color 0.2s, background 0.2s;
    }
    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus { border-color: var(--blue); background: white; }

    .form-group textarea { resize: vertical; min-height: 120px; }

    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
      padding: 0.9rem 2rem;
      background: var(--blue); color: white; border: none;
      border-radius: 50px; font-size: 0.9375rem; font-weight: 600; letter-spacing: 0.03em;
      cursor: pointer; text-decoration: none;
      box-shadow: 0 4px 16px rgba(123,189,212,0.35);
      transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    }
    .btn:hover { background: var(--blue-mid); transform: translateY(-1px); box-shadow: 0 6px 22px rgba(123,189,212,0.45); }
    .btn-full { width: 100%; }

    /* ===================== FOOTER ===================== */
    .site-footer { background: var(--navy); color: rgba(255,255,255,0.75); padding: 3.75rem 0 0; }

    .footer-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 2.5rem; padding-bottom: 3rem; }

    .footer-brand .nav-logo { margin-bottom: 0.875rem; }
    .footer-brand .logo-main { color: white; font-size: 1.45rem; }
    .footer-brand .logo-sub  { color: var(--blue); }
    .footer-brand p { font-size: 0.875rem; line-height: 1.75; max-width: 280px; }

    .footer-social { display: flex; gap: 0.5rem; margin-top: 1.375rem; }

    .social-icon {
      width: 36px; height: 36px;
      background: rgba(255,255,255,0.08); border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      color: rgba(255,255,255,0.55);
      transition: background 0.2s, color 0.2s; cursor: default;
    }
    .social-icon:hover { background: rgba(255,255,255,0.14); color: white; }

    .footer-col h4 {
