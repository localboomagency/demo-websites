---
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Peak Performance — Train Like You Mean It</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>

    <nav>
      <div class="nav-inner">
        <a href="/" class="back-link">&#8592; Back to demos</a>
        <span class="logo">PEAK</span>
        <a href="#join" class="nav-cta">Join Now</a>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-inner">
        <p class="eyebrow">Est. 2019 &nbsp;&middot;&nbsp; London Fields</p>
        <h1>Train<br />like you<br />mean it.</h1>
        <p class="hero-sub">No machines. No mirrors. No excuses. Just barbell, bodyweight, and the work that changes everything.</p>
        <div class="hero-actions">
          <a href="#join" class="btn-primary">Start Free Trial</a>
          <a href="#classes" class="btn-outline">View Classes</a>
        </div>
      </div>
      <div class="hero-scroll">&#8595;</div>
    </section>

    <section class="stats">
      <div class="stat">
        <span class="stat-num">1,200+</span>
        <span class="stat-label">Members</span>
      </div>
      <div class="stat">
        <span class="stat-num">40+</span>
        <span class="stat-label">Classes weekly</span>
      </div>
      <div class="stat">
        <span class="stat-num">6am–10pm</span>
        <span class="stat-label">Open daily</span>
      </div>
      <div class="stat">
        <span class="stat-num">5&#9733;</span>
        <span class="stat-label">Average rating</span>
      </div>
    </section>

    <section class="features">
      <div class="container">
        <p class="section-label">Why Peak</p>
        <h2>Different by design</h2>
        <div class="features-grid">
          <div class="feature">
            <span class="feature-icon">&#9889;</span>
            <h3>High-intensity classes</h3>
            <p>HIIT, Olympic lifting, kettlebell circuits, and metabolic conditioning &mdash; all programmed by coaches who compete.</p>
          </div>
          <div class="feature">
            <span class="feature-icon">&#127947;</span>
            <h3>Expert coaching</h3>
            <p>Every session is coached. Every rep is watched. Our trainers hold professional certifications and won&rsquo;t let you cheat a squat.</p>
          </div>
          <div class="feature">
            <span class="feature-icon">&#128202;</span>
            <h3>Tracked progress</h3>
            <p>Our app tracks every lift, every sprint, every PR. Watch your numbers move &mdash; it&rsquo;s addictive.</p>
          </div>
          <div class="feature">
            <span class="feature-icon">&#129309;</span>
            <h3>Real community</h3>
            <p>The people here will remember your name by session two. We celebrate each other&rsquo;s wins. That&rsquo;s not marketing &mdash; it&rsquo;s just how it is.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="classes" id="classes">
      <div class="container">
        <p class="section-label">The Schedule</p>
        <h2>This week&rsquo;s classes</h2>
        <div class="class-list">
          <div class="class-item">
            <span class="class-tag">Mon&ndash;Fri</span>
            <div class="class-info">
              <h3>6am Barbell Club</h3>
              <p>Start your day with compound lifts. Squat, deadlift, press. 60 minutes.</p>
            </div>
            <span class="class-spots">8 spots</span>
          </div>
          <div class="class-item">
            <span class="class-tag">Mon / Wed / Fri</span>
            <div class="class-info">
              <h3>MetCon</h3>
              <p>Metabolic conditioning. High intensity. Short rest. Maximum output.</p>
            </div>
            <span class="class-spots">12 spots</span>
          </div>
          <div class="class-item">
            <span class="class-tag">Tue / Thu</span>
            <div class="class-info">
              <h3>Olympic Lifting</h3>
              <p>Snatch and clean &amp; jerk technique. All levels welcome. Coach-led.</p>
            </div>
            <span class="class-spots">6 spots</span>
          </div>
          <div class="class-item">
            <span class="class-tag">Sat / Sun</span>
            <div class="class-info">
              <h3>Weekend Warrior</h3>
              <p>90-minute partner workout. Our most popular session. Book early.</p>
            </div>
            <span class="class-spots">20 spots</span>
          </div>
        </div>
      </div>
    </section>

    <section class="pricing" id="join">
      <div class="container">
        <p class="section-label">Membership</p>
        <h2>Simple pricing</h2>
        <div class="pricing-grid">
          <div class="plan">
            <h3>Flex</h3>
            <p class="plan-price"><span class="price-num">&pound;55</span>/mo</p>
            <p class="plan-desc">8 classes per month. Open gym access 7am&ndash;5pm on weekdays.</p>
            <ul class="plan-features">
              <li>8 class credits</li>
              <li>App access</li>
              <li>Progress tracking</li>
              <li>Community access</li>
            </ul>
            <a href="#" class="btn-outline">Get started</a>
          </div>
          <div class="plan plan-featured">
            <span class="plan-badge">Most popular</span>
            <h3>Unlimited</h3>
            <p class="plan-price"><span class="price-num">&pound;85</span>/mo</p>
            <p class="plan-desc">Unlimited classes, full gym access, and one free PT session per month.</p>
            <ul class="plan-features">
              <li>Unlimited classes</li>
              <li>Full gym access</li>
              <li>1&times; PT session/mo</li>
              <li>Priority booking</li>
            </ul>
            <a href="#" class="btn-primary">Get started</a>
          </div>
          <div class="plan">
            <h3>Team</h3>
            <p class="plan-price"><span class="price-num">&pound;65</span>/mo <span class="price-note">per person</span></p>
            <p class="plan-desc">Groups of 4+. Everything in Unlimited, with corporate invoicing available.</p>
            <ul class="plan-features">
              <li>Unlimited classes</li>
              <li>Full gym access</li>
              <li>Group billing</li>
              <li>Dedicated coach</li>
            </ul>
            <a href="#" class="btn-outline">Get started</a>
          </div>
        </div>
      </div>
    </section>

    <footer>
      <div class="container">
        <div class="footer-inner">
          <div>
            <span class="footer-logo">PEAK</span>
            <p>The Arches, London Fields, E8 3PA</p>
            <p>hello@peakperformance.co.uk</p>
          </div>
          <div class="footer-links">
            <a href="#">Instagram</a>
            <a href="#">Classes</a>
            <a href="#">Membership</a>
            <a href="/">Demo index</a>
          </div>
        </div>
        <p class="footer-copy">&copy; 2024 Peak Performance Ltd</p>
      </div>
    </footer>

  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black: #0a0a0a;
    --dark: #111111;
    --card: #1a1a1a;
    --border: #2a2a2a;
    --yellow: #f0d500;
    --yellow-dark: #d4bb00;
    --white: #ffffff;
    --muted: #888888;
    --display: 'Bebas Neue', sans-serif;
    --body: 'Inter', sans-serif;
  }

  body {
    font-family: var(--body);
    background: var(--black);
    color: var(--white);
    line-height: 1.6;
  }

  /* ── Nav ── */
  nav {
    position: sticky;
    top: 0;
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    z-index: 100;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .back-link {
    font-size: 0.8125rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--white); }

  .logo {
    font-family: var(--display);
    font-size: 1.5rem;
    letter-spacing: 0.1em;
    color: var(--yellow);
  }

  .nav-cta {
    background: var(--yellow);
    color: var(--black);
    padding: 8px 20px;
    border-radius: 2px;
    text-decoration: none;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: background 0.2s;
  }
  .nav-cta:hover { background: var(--yellow-dark); }

  /* ── Hero ── */
  .hero {
    min-height: calc(100vh - 57px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 24px;
    background: var(--dark);
    position: relative;
    border-bottom: 1px solid var(--border);
  }

  .hero-inner { max-width: 1200px; margin: 0 auto; width: 100%; }

  .eyebrow {
    font-size: 0.8125rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 24px;
    display: block;
  }

  .hero h1 {
    font-family: var(--display);
    font-size: clamp(5rem, 14vw, 10rem);
    line-height: 0.95;
    letter-spacing: 0.03em;
    margin-bottom: 32px;
  }

  .hero-sub {
    font-size: 1.0625rem;
    color: var(--muted);
    max-width: 480px;
    margin-bottom: 48px;
    font-weight: 300;
  }

  .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }

  .btn-primary {
    display: inline-block;
    background: var(--yellow);
    color: var(--black);
    padding: 14px 32px;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: var(--yellow-dark); }

  .btn-outline {
    display: inline-block;
    color: var(--white);
    padding: 14px 32px;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid var(--border);
    border-radius: 2px;
    transition: border-color 0.2s;
  }
  .btn-outline:hover { border-color: var(--white); }

  .hero-scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    color: var(--muted);
    font-size: 1.25rem;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  /* ── Stats ── */
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid var(--border);
  }

  .stat {
    padding: 36px 24px;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .stat:last-child { border-right: none; }

  .stat-num {
    font-family: var(--display);
    font-size: 2.25rem;
    letter-spacing: 0.04em;
    color: var(--yellow);
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label {
    font-size: 0.8125rem;
    color: var(--muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ── Shared ── */
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

  .section-label {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 12px;
  }

  /* ── Features ── */
  .features {
    padding: 96px 24px;
    border-bottom: 1px solid var(--border);
  }

  .features h2 {
    font-family: var(--display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: 0.04em;
    margin-bottom: 64px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .feature { background: var(--dark); padding: 40px 32px; }

  .feature-icon { font-size: 1.75rem; display: block; margin-bottom: 20px; }

  .feature h3 {
    font-family: var(--display);
    font-size: 1.375rem;
    letter-spacing: 0.04em;
    margin-bottom: 12px;
  }

  .feature p { font-size: 0.9375rem; color: var(--muted); font-weight: 300; line-height: 1.65; }

  /* ── Classes ── */
  .classes {
    padding: 96px 24px;
    background: var(--dark);
    border-bottom: 1px solid var(--border);
  }

  .classes h2 {
    font-family: var(--display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: 0.04em;
    margin-bottom: 48px;
  }

  .class-list { display: flex; flex-direction: column; }

  .class-item {
    background: var(--card);
    padding: 28px 32px;
    display: grid;
    grid-template-columns: 160px 1fr auto;
    gap: 24px;
    align-items: center;
    border: 1px solid var(--border);
    border-top: none;
  }
  .class-item:first-child { border-top: 1px solid var(--border); }

  .class-tag {
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--yellow);
  }

  .class-info h3 {
    font-family: var(--display);
    font-size: 1.25rem;
    letter-spacing: 0.04em;
    margin-bottom: 4px;
  }

  .class-info p { font-size: 0.9rem; color: var(--muted); font-weight: 300; }

  .class-spots { font-size: 0.8125rem; color: var(--muted); white-space: nowrap; }

  /* ── Pricing ── */
  .pricing {
    padding: 96px 24px;
    border-bottom: 1px solid var(--border);
  }

  .pricing h2 {
    font-family: var(--display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: 0.04em;
    margin-bottom: 48px;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .plan { background: var(--dark); padding: 40px 32px; position: relative; }
  .plan-featured { background: var(--card); }

  .plan-badge {
    display: inline-block;
    background: var(--yellow);
    color: var(--black);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 2px;
    margin-bottom: 20px;
    display: block;
  }

  .plan h3 {
    font-family: var(--display);
    font-size: 1.75rem;
    letter-spacing: 0.06em;
    margin-bottom: 12px;
  }

  .plan-price {
    font-size: 1rem;
    color: var(--muted);
    margin-bottom: 16px;
    display: flex;
    align-items: baseline;
    gap: 4px;
  }

  .price-num {
    font-family: var(--display);
    font-size: 2.5rem;
    color: var(--white);
    letter-spacing: 0.04em;
  }

  .price-note { font-size: 0.8125rem; }

  .plan-desc { font-size: 0.9375rem; color: var(--muted); font-weight: 300; margin-bottom: 28px; line-height: 1.6; }

  .plan-features { list-style: none; margin-bottom: 36px; }

  .plan-features li {
    font-size: 0.9375rem;
    color: var(--muted);
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .plan-features li::before { content: '&#10003;'; color: var(--yellow); font-size: 0.875rem; }

  /* ── Footer ── */
  footer { background: var(--dark); padding: 48px 24px; }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 40px;
    gap: 48px;
  }

  .footer-logo {
    font-family: var(--display);
    font-size: 2rem;
    letter-spacing: 0.1em;
    color: var(--yellow);
    display: block;
    margin-bottom: 12px;
  }

  footer p { font-size: 0.875rem; color: var(--muted); margin-bottom: 4px; }

  .footer-links { display: flex; flex-direction: column; gap: 12px; text-align: right; }

  .footer-links a { color: var(--muted); text-decoration: none; font-size: 0.875rem; transition: color 0.2s; }
  .footer-links a:hover { color: var(--white); }

  .footer-copy {
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    font-size: 0.8125rem;
    color: #555;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .stats { grid-template-columns: repeat(2, 1fr); }
    .stat:nth-child(2) { border-right: none; }
    .stat:nth-child(3) { border-right: 1px solid var(--border); }
    .pricing-grid { grid-template-columns: 1fr; }
    .class-item { grid-template-columns: 1fr; gap: 8px; }
    .class-spots { display: none; }
  }

  @media (max-width: 640px) {
    .hero h1 { font-size: 5rem; }
    .hero-actions { flex-direction: column; }
    .features, .classes, .pricing { padding: 64px 24px; }
    .footer-inner { flex-direction: column; }
    .footer-links { text-align: left; }
  }
</style>
