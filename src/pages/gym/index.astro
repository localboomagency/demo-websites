<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Peak Performance Gym — London Fields</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- 1. NAV -->
    <nav>
      <div class="container nav-inner">
        <span class="logo">PEAK</span>
        <div class="nav-links">
          <a href="#classes">Classes</a>
          <a href="#reviews">Reviews</a>
          <a href="#about">About</a>
          <a href="#trial">Contact</a>
        </div>
        <a href="tel:02071234567" class="nav-phone">
          <!-- PLACEHOLDER: phone number -->
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          020 7123 4567
        </a>
        <button class="nav-hamburger" aria-label="Open menu">
          <svg width="20" height="14" viewBox="0 0 20 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="0" y1="1" x2="20" y2="1"/>
            <line x1="0" y1="7" x2="20" y2="7"/>
            <line x1="0" y1="13" x2="20" y2="13"/>
          </svg>
        </button>
      </div>
    </nav>

    <!-- 2. HERO -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-content">
          <p class="eyebrow">Est. 2019 &nbsp;&middot;&nbsp; London Fields</p>
          <h1>Independent Private Gym in Exeter</h1>
          <p class="hero-sub">No machines. No mirrors. No excuses. Just barbell, bodyweight, and expert coaching that changes everything.</p>
          <ul class="hero-bullets">
            <li>Expert coaching in every session, no exceptions</li>
            <li>40+ classes per week across all levels</li>
            <li>First session completely free &mdash; no hard sell</li>
          </ul>
          <!-- PLACEHOLDER: replace with real Google review data -->
          <div class="google-review">
            <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#4285F4" d="M43.6 20.1H42V20H24v8h11.3C33.7 32.9 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.1 8 2.9l5.7-5.7C34.5 6.5 29.5 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.6-.4-3.9z"/><path fill="#EA4335" d="M6.3 14.7l6.6 4.8C14.6 16.1 19 13 24 13c3.1 0 5.8 1.1 8 2.9l5.7-5.7C34.5 6.5 29.5 4 24 4 16.3 4 9.7 8.4 6.3 14.7z"/><path fill="#FBBC05" d="M24 44c5.2 0 9.9-1.9 13.4-5.1l-6.2-5.2C29.3 35.3 26.8 36 24 36c-5.2 0-9.7-3.1-11.3-7.9l-6.5 5.1C9.6 39.5 16.3 44 24 44z"/><path fill="#34A853" d="M43.6 20.1H42V20H24v8h11.3c-.8 2.3-2.3 4.2-4.3 5.6l6.2 5.2C37 39 44 33 44 24c0-1.3-.1-2.6-.4-3.9z"/></svg>
            <span class="review-stars-hero">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span class="review-text-hero">4.9 &nbsp;&middot;&nbsp; 386 reviews on Google</span>
          </div>
          <div class="hero-actions">
            <a href="tel:02071234567" class="btn-primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              Call: 020 7123 4567
            </a>
            <a href="#trial" class="btn-outline">Book a Free Trial</a>
          </div>
        </div>
        <div class="hero-image">
          <img src="/images/gym/hero.jpg" alt="Athlete loading a barbell at Peak Performance Gym" />
        </div>
      </div>
    </section>

    <!-- 3. TRUST BAR -->
    <div class="trust-bar">
      <div class="container trust-inner">
        <div class="trust-item">
          <span class="trust-num">Est. 2019</span>
          <span class="trust-label">5 years strong</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="trust-num">1,200+</span>
          <span class="trust-label">Active members</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="trust-num">40+</span>
          <span class="trust-label">Classes per week</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="trust-num">4.9&#9733;</span>
          <span class="trust-label">386 Google reviews</span>
        </div>
      </div>
    </div>

    <!-- 4. SERVICES / CLASSES -->
    <section class="classes" id="classes">
      <div class="container">
        <p class="section-label">What we offer</p>
        <h2>Classes &amp; Training</h2>
        <div class="classes-grid">
          <div class="class-card">
            <span class="class-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></span>
            <h3>HIIT</h3>
            <p>High-intensity intervals engineered for fat loss and conditioning. 45 minutes. Maximum output. Scaled to your level.</p>
            <span class="class-freq">Mon &middot; Wed &middot; Fri &middot; Sat</span>
          </div>
          <div class="class-card">
            <span class="class-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="1" y="11" width="2.5" height="2" rx="0.5"/><rect x="4.5" y="9" width="2.5" height="6" rx="0.5"/><line x1="7" y1="12" x2="17" y2="12"/><rect x="17" y="9" width="2.5" height="6" rx="0.5"/><rect x="20.5" y="11" width="2.5" height="2" rx="0.5"/></svg></span>
            <h3>Barbell Club</h3>
            <p>The 6am session that builds champions. Squat, deadlift, press. Coached every rep. 60 minutes of serious work.</p>
            <span class="class-freq">Mon &ndash; Fri, 6am</span>
          </div>
          <div class="class-card">
            <span class="class-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg></span>
            <h3>Olympic Lifting</h3>
            <p>Snatch and clean &amp; jerk technique taught properly. All levels welcome. You&rsquo;ll be surprised how quickly you progress.</p>
            <span class="class-freq">Tue &middot; Thu</span>
          </div>
          <div class="class-card">
            <span class="class-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 3z"/></svg></span>
            <h3>MetCon</h3>
            <p>Metabolic conditioning. Barbells, kettlebells, rowers. Short rest, maximum output. The session that earns your weekend.</p>
            <span class="class-freq">Mon &middot; Wed &middot; Fri</span>
          </div>
          <div class="class-card">
            <span class="class-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg></span>
            <h3>Mobility &amp; Recovery</h3>
            <p>The session serious athletes actually need. Structured movement work that keeps you training longer and harder.</p>
            <span class="class-freq">Tue &middot; Thu &middot; Sun</span>
          </div>
          <div class="class-card">
            <span class="class-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
            <h3>Personal Training</h3>
            <p>1-to-1 with a certified coach. Fully bespoke programming, nutrition guidance, and accountability that produces results.</p>
            <span class="class-freq">By appointment</span>
          </div>
        </div>
      </div>
    </section>

    <!-- 5. REVIEWS -->
    <section class="reviews">
      <div class="container">
        <div class="reviews-header">
          <div>
            <p class="section-label">Member reviews</p>
            <h2>386 five-star ratings</h2>
          </div>
          <div class="rating-badge">
            <span class="rating-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span class="rating-score">4.9 on Google</span>
          </div>
        </div>
        <!-- PLACEHOLDER: replace with real reviews -->
        <div class="reviews-grid">
          <div class="review-card">
            <div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <blockquote>&ldquo;I&rsquo;ve been to a lot of gyms. Peak is different &mdash; the coaches actually coach, the community actually shows up, and I hit a 20kg PB on my deadlift within three months. Nothing else comes close.&rdquo;</blockquote>
            <div class="reviewer">
              <span class="reviewer-name">Daniel K.</span>
              <span class="reviewer-location">Hackney</span>
            </div>
          </div>
          <div class="review-card">
            <div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <blockquote>&ldquo;Nervous to join at first, but the team made me feel welcome immediately. Six months in and I can&rsquo;t imagine training anywhere else. The 6am barbell club is my favourite hour of the day.&rdquo;</blockquote>
            <div class="reviewer">
              <span class="reviewer-name">Priya S.</span>
              <span class="reviewer-location">Bethnal Green</span>
            </div>
          </div>
          <div class="review-card">
            <div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <blockquote>&ldquo;The programming here is the best I&rsquo;ve seen outside of competitive CrossFit boxes. If you want to get genuinely stronger &mdash; not just sweaty &mdash; this is the place. The coaches are world-class.&rdquo;</blockquote>
            <div class="reviewer">
              <span class="reviewer-name">Tom W.</span>
              <span class="reviewer-location">Bow</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 6. WHY US / ABOUT -->
    <section class="about" id="about">
      <div class="container">
        <div class="about-grid">
          <div class="about-text">
            <p class="section-label">Why Peak</p>
            <h2>Different by design</h2>
            <p>Most gyms sell you a fob and leave you to it. Peak was built differently &mdash; every session is coached, every rep is watched, and your name will be known by your second visit.</p>
            <p>We don&rsquo;t do machines or mirrored walls. We do barbells, expertise, and a community that shows up for each other. That&rsquo;s not a pitch &mdash; ask any of our 1,200 members.</p>
          </div>
          <div class="about-pillars">
            <div class="pillar">
              <span class="pillar-num">01</span>
              <div class="pillar-body">
                <strong>Expert coaching, every session</strong>
                <p>All coaches hold professional certifications. No session goes unchecked. Technique comes before load, always.</p>
              </div>
            </div>
            <div class="pillar">
              <span class="pillar-num">02</span>
              <div class="pillar-body">
                <strong>Results-led programming</strong>
                <p>Every class is periodised. Nothing is random. You&rsquo;ll see measurable progress within eight weeks &mdash; we back that claim.</p>
              </div>
            </div>
            <div class="pillar">
              <span class="pillar-num">03</span>
              <div class="pillar-body">
                <strong>A community that means it</strong>
                <p>The people here will remember your name by session two. We celebrate each other&rsquo;s wins. That&rsquo;s just how it is.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 7. CONTACT / TRIAL FORM -->
    <section class="contact" id="trial">
      <div class="container">
        <div class="contact-grid">
          <div class="contact-info">
            <p class="section-label">Book your free trial</p>
            <h2>Come in and train for free</h2>
            <p>Your first session is on us. No commitment, no hard sell. Just one session with a coach to see if Peak is the right fit for you.</p>
            <ul class="contact-details">
              <li>
                <span class="detail-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
                <span>The Arches, London Fields, E8 3PA</span>
              </li>
              <li>
                <span class="detail-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg></span>
                <a href="tel:02071234567">020 7123 4567</a>
                <!-- PLACEHOLDER: phone number -->
              </li>
              <li>
                <span class="detail-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span>
                <a href="mailto:hello@peakperformance.co.uk">hello@peakperformance.co.uk</a>
              </li>
              <li>
                <span class="detail-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
                <span>Monday &ndash; Friday: 6am &ndash; 10pm<br />Saturday &ndash; Sunday: 8am &ndash; 7pm</span>
              </li>
            </ul>
          </div>
          <form class="contact-form">
            <div class="form-row">
              <div class="form-group">
                <label for="name">Your name</label>
                <input type="text" id="name" name="name" placeholder="Alex Johnson" required />
              </div>
              <div class="form-group">
                <label for="phone">Phone number</label>
                <input type="tel" id="phone" name="phone" placeholder="07700 900000" />
              </div>
            </div>
            <div class="form-group">
              <label for="email">Email address</label>
              <input type="email" id="email" name="email" placeholder="alex@example.com" required />
            </div>
            <div class="form-group">
              <label for="message">Tell us about your goals</label>
              <textarea id="message" name="message" rows="4" placeholder="What are you training for? Any injuries we should know about?"></textarea>
            </div>
            <button type="submit" class="btn-submit">Book My Free Trial</button>
          </form>
        </div>
      </div>
    </section>

    <!-- 8. FOOTER -->
    <footer>
      <div class="container">
        <div class="footer-inner">
          <div class="footer-brand">
            <span class="footer-logo">PEAK</span>
            <p>The Arches, London Fields<br />London E8 3PA</p>
            <div class="footer-social">
              <span aria-label="Instagram"><svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg></span>
              <span aria-label="Facebook"><svg viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></span>
              <span aria-label="X"><svg viewBox="0 0 24 24"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg></span>
              <span aria-label="YouTube"><svg viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></span>
            </div>
          </div>
          <div class="footer-contact">
            <a href="tel:02071234567">020 7123 4567</a>
            <!-- PLACEHOLDER: phone number -->
            <a href="mailto:hello@peakperformance.co.uk">hello@peakperformance.co.uk</a>
          </div>
          <div class="footer-hours">
            <strong>Hours</strong>
            <p>Mon &ndash; Fri &nbsp;&middot;&nbsp; 6am &ndash; 10pm</p>
            <p>Sat &ndash; Sun &nbsp;&middot;&nbsp; 8am &ndash; 7pm</p>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2024 Peak Performance Ltd</p>
        </div>
      </div>
    </footer>

    <!-- PLACEHOLDER: replace with real WhatsApp number -->
    <a href="https://wa.me/441234567890" class="whatsapp-btn" aria-label="Chat on WhatsApp">
