---
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Teign Plumbing &amp; Heating | Emergency Plumber in Teignmouth</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      color: #1C2B3A;
      background: #fff;
      line-height: 1.6;
    }

    a { text-decoration: none; color: inherit; }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* ─── TOP BANNER ─── */
    .top-banner {
      background: #F8A323;
      color: #1C2B3A;
      text-align: center;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      padding: 0.45rem 1rem;
    }

    /* ─── NAV ─── */
    nav {
      background: #FFF8F0;
      border-bottom: 1px solid #DDE8EF;
      position: sticky;
      top: 0;
      z-index: 200;
    }

    .nav-inner {
      display: flex;
      align-items: center;
      gap: 2rem;
      height: 68px;
    }

    .nav-logo {
      display: inline-flex;
      align-items: center;
      flex-shrink: 0;
    }

    .nav-logo img {
      display: block;
      width: 210px;
      height: auto;
    }

    .nav-links {
      display: flex;
      gap: 2.2rem;
      list-style: none;
      flex: 1;
    }

    .nav-links a {
      font-size: 0.88rem;
      font-weight: 500;
      color: #4B5563;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: #5BA3C9; }

    .nav-phone {
      background: #5BA3C9;
      color: #fff;
      padding: 0.85rem 1.6rem;
      border-radius: 6px;
      font-weight: 700;
      font-size: 0.93rem;
      white-space: nowrap;
      flex-shrink: 0;
      transition: background 0.2s, transform 0.15s;
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
    }

    .nav-phone:hover { background: #4A8DB5; transform: translateY(-1px); }

    .nav-socials {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-shrink: 0;
    }

    .nav-social-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 34px;
      height: 34px;
      border-radius: 6px;
      color: #5BA3C9;
      border: 1px solid #5BA3C9;
      transition: color 0.2s, border-color 0.2s, background 0.2s;
    }

    .nav-social-icon:hover {
      color: #fff;
      background: #5BA3C9;
      border-color: #5BA3C9;
    }

    .nav-quote {
      background: transparent;
      color: #5BA3C9;
      padding: 0.75rem 1.25rem;
      border-radius: 6px;
      font-weight: 700;
      font-size: 0.88rem;
      border: 2px solid #5BA3C9;
      white-space: nowrap;
      flex-shrink: 0;
      transition: background 0.2s, color 0.2s, transform 0.15s;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }

    .nav-quote:hover {
      background: #5BA3C9;
      color: #fff;
      transform: translateY(-1px);
    }

    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: 1px solid #DDE8EF;
      border-radius: 6px;
      padding: 0.5rem 0.6rem;
      cursor: pointer;
      flex-shrink: 0;
    }

    .nav-hamburger span {
      display: block;
      width: 20px;
      height: 2px;
      background: #1C2B3A;
      border-radius: 2px;
    }

    /* ─── HERO ─── */
    .hero {
      position: relative;
      background: #0D1B2A;
      overflow: hidden;
      display: flex;
      align-items: center;
      padding: 3rem 0 3.5rem;
      min-height: 480px;
    }

    .hero-bg-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
    }

    .hero-bg-gradient {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(13,27,42,0.97) 0%,
        rgba(13,27,42,0.88) 55%,
        rgba(13,27,42,0.68) 100%
      );
    }

    .hero-content {
      position: relative;
      z-index: 1;
      max-width: 680px;
      width: 100%;
      margin: 0 auto;
      text-align: center;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      background: rgba(248,163,35,0.12);
      color: #F8A323;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.35rem 0.9rem;
      border-radius: 100px;
      border: 1px solid rgba(248,163,35,0.3);
      margin-bottom: 0.9rem;
    }

    .hero h1 {
      font-size: clamp(2rem, 4.5vw, 3.25rem);
      font-weight: 800;
      color: #fff;
      line-height: 1.08;
      margin-bottom: 0.75rem;
    }

    .hero-sub {
      font-size: 1rem;
      color: rgba(255,255,255,0.68);
      line-height: 1.65;
      margin-bottom: 1rem;
      max-width: 520px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-bullets {
      list-style: none;
      margin-bottom: 1.1rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem 2.5rem;
      max-width: 540px;
      margin-left: auto;
      margin-right: auto;
      text-align: left;
    }

    .hero-bullets li {
      font-size: 0.91rem;
      color: rgba(255,255,255,0.88);
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 0.65rem;
    }

    .bullet-check {
      width: 18px;
      height: 18px;
      min-width: 18px;
      background: rgba(91,163,201,0.16);
      border: 1px solid rgba(91,163,201,0.4);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #5BA3C9;
    }

    /* Review widgets — dark variant */
    .review-widgets {
      display: flex;
      justify-content: center;
      gap: 0.6rem;
      flex-wrap: wrap;
      margin-bottom: 1.2rem;
    }

    .review-widget {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 8px;
      padding: 0.48rem 0.9rem;
    }

    .review-stars {
      color: #FBBC04;
      font-size: 0.9rem;
      letter-spacing: -1px;
    }

    .review-text {
      font-size: 0.8rem;
      color: rgba(255,255,255,0.82);
      font-weight: 500;
    }

    .hero-ctas {
      display: flex;
      justify-content: center;
      gap: 0.85rem;
      flex-wrap: wrap;
    }

    .btn-primary {
      background: #5BA3C9;
      color: #fff;
      padding: 0.85rem 1.6rem;
      border-radius: 6px;
      font-weight: 700;
      font-size: 0.93rem;
      transition: background 0.2s, transform 0.15s;
      border: none;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
    }

    .btn-primary:hover {
      background: #4A8DB5;
      transform: translateY(-1px);
    }

    .btn-secondary {
      background: transparent;
      color: #fff;
      padding: 0.85rem 1.6rem;
      border-radius: 6px;
      font-weight: 700;
      font-size: 0.93rem;
      border: 2px solid rgba(255,255,255,0.38);
      transition: background 0.2s, transform 0.15s;
      display: inline-block;
    }

    .btn-secondary:hover {
      background: rgba(255,255,255,0.1);
      transform: translateY(-1px);
    }

    /* ─── TRUST BAR ─── */
    .trust-bar {
      background: #FAF8F4;
      border-top: 1px solid #EDE8E0;
      border-bottom: 1px solid #EDE8E0;
      padding: 2rem 0;
    }

    .trust-bar-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      text-align: center;
    }

    .trust-item {
      padding: 0.75rem 1rem;
    }

    .trust-number {
      font-size: 1.65rem;
      font-weight: 800;
      color: #1C2B3A;
      line-height: 1;
      margin-bottom: 0.3rem;
    }

    .trust-label {
      font-size: 0.75rem;
      color: #6B7280;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* ─── SERVICES ─── */
    .services {
      background: #fff;
      padding: 5rem 0;
    }

    .section-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .section-header h2 {
      font-size: clamp(1.5rem, 3vw, 2.1rem);
      font-weight: 800;
      color: #1C2B3A;
      margin-bottom: 0.55rem;
    }

    .section-header p {
      color: #6B7280;
      font-size: 0.95rem;
      max-width: 500px;
      margin: 0 auto;
      line-height: 1.65;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    .service-card {
      background: #FAF8F4;
      border: 1px solid #EDE8E0;
      border-radius: 10px;
      padding: 1.75rem;
      transition: box-shadow 0.2s, transform 0.2s;
    }

    .service-card:hover {
      box-shadow: 0 4px 18px rgba(0,0,0,0.07);
      transform: translateY(-2px);
    }

    .service-card h3 {
      font-size: 1rem;
      font-weight: 700;
      color: #1C2B3A;
      margin-bottom: 0.5rem;
    }

    .service-card p {
      font-size: 0.87rem;
      color: #6B7280;
      line-height: 1.65;
    }

    /* ─── REVIEWS ─── */
    .reviews {
      background: #FAF8F4;
      padding: 5rem 0;
    }

    .reviews-meta {
      text-align: center;
      margin-bottom: 2.5rem;
    }

    .reviews-score {
      font-size: 3rem;
      font-weight: 800;
      color: #1C2B3A;
      line-height: 1;
    }

    .reviews-stars {
      color: #FBBC04;
      font-size: 1.3rem;
      margin: 0.3rem 0;
    }

    .reviews-count {
      font-size: 0.88rem;
      color: #6B7280;
      margin-bottom: 1.2rem;
    }

    .reviews-meta h2 {
      font-size: clamp(1.4rem, 2.5vw, 1.9rem);
      font-weight: 800;
      color: #1C2B3A;
    }

    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    .review-card {
      background: #fff;
      border: 1px solid #EDE8E0;
      border-radius: 10px;
      padding: 1.6rem;
    }

    .review-card-stars {
      color: #FBBC04;
      font-size: 0.9rem;
      margin-bottom: 0.85rem;
      letter-spacing: -0.5px;
    }

    .review-quote {
      font-size: 0.88rem;
      color: #374151;
      line-height: 1.65;
      margin-bottom: 1rem;
      font-style: italic;
    }

    .review-author {
      font-size: 0.85rem;
      font-weight: 700;
      color: #1C2B3A;
    }

    .review-location {
      font-size: 0.78rem;
      color: #9CA3AF;
      margin-top: 0.1rem;
    }

    /* ─── ABOUT ─── */
    .about {
      background: #fff;
      padding: 5rem 0;
    }

    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .about-content h2 {
      font-size: clamp(1.4rem, 2.5vw, 2rem);
      font-weight: 800;
      color: #1C2B3A;
      line-height: 1.2;
      margin-bottom: 1.2rem;
    }

    .about-content p {
      font-size: 0.93rem;
      color: #4B5563;
      line-height: 1.7;
      margin-bottom: 1rem;
    }

    .about-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .about-stat {
      background: #EBF5FB;
      border-radius: 10px;
      padding: 1.3rem;
    }

    .about-stat-number {
      font-size: 1.6rem;
      font-weight: 800;
      color: #4A8DB5;
      line-height: 1;
      margin-bottom: 0.3rem;
    }

    .about-stat-label {
      font-size: 0.78rem;
      color: #4B5563;
      font-weight: 500;
      line-height: 1.35;
    }

    /* ─── CONTACT ─── */
    .contact {
      background: #EBF5FB;
      padding: 5rem 0;
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 4rem;
      align-items: start;
    }

    .contact-info h2 {
      font-size: clamp(1.4rem, 2.5vw, 2rem);
      font-weight: 800;
      color: #1C2B3A;
      line-height: 1.2;
      margin-bottom: 0.8rem;
    }

    .contact-info > p {
      font-size: 0.93rem;
      color: #4B5563;
      line-height: 1.65;
      margin-bottom: 2rem;
    }

    .contact-detail {
      margin-bottom: 1rem;
    }

    .contact-detail-label {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: #9CA3AF;
      margin-bottom: 0.2rem;
    }

    .contact-detail-value {
      font-size: 0.93rem;
      color: #1C2B3A;
      font-weight: 600;
      line-height: 1.5;
    }

    .contact-detail-value a { color: #1C2B3A; }
    .contact-detail-value a:hover { color: #5BA3C9; text-decoration: underline; }

    .contact-form {
      background: #fff;
      border-radius: 12px;
      padding: 2.5rem;
      box-shadow: 0 2px 14px rgba(0,0,0,0.06);
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .form-group {
      margin-bottom: 1.2rem;
    }

    .form-group label {
      display: block;
      font-size: 0.75rem;
      font-weight: 700;
      color: #374151;
      margin-bottom: 0.4rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .form-group input,
    .form-group textarea {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1.5px solid #DDE8EF;
      border-radius: 6px;
      font-family: inherit;
      font-size: 0.93rem;
      color: #1C2B3A;
      background: #fff;
      transition: border-color 0.2s;
      outline: none;
    }

    .form-group input:focus,
    .form-group textarea:focus { border-color: #5BA3C9; }

    .form-group textarea {
      resize: vertical;
      min-height: 110px;
    }

    .form-submit {
      width: 100%;
      background: #5BA3C9;
      color: #fff;
      border: none;
      padding: 0.9rem;
      border-radius: 6px;
      font-family: inherit;
      font-size: 0.97rem;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.2s;
    }

    .form-submit:hover { background: #4A8DB5; }

    /* ─── FOOTER ─── */
    footer {
      background: #112031;
      color: #94A3B8;
      padding: 3.5rem 0 2rem;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: 3rem;
      margin-bottom: 2.5rem;
    }

    .footer-brand-name {
      font-size: 1.05rem;
      font-weight: 800;
      color: #fff;
      margin-bottom: 0.5rem;
    }

    .footer-brand-desc {
      font-size: 0.83rem;
      line-height: 1.65;
      color: #64748B;
      margin-bottom: 1.2rem;
    }

    .footer-social {
      display: flex;
      gap: 0.6rem;
    }

    .footer-social-item {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 34px;
      height: 34px;
      border-radius: 6px;
      background: rgba(255,255,255,0.07);
      color: #94A3B8;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    .footer-col-title {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #fff;
      margin-bottom: 1.1rem;
    }

    .footer-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
    }

    .footer-list li {
      font-size: 0.83rem;
      color: #64748B;
      line-height: 1.5;
    }

    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,0.08);
      padding-top: 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .footer-copy {
      font-size: 0.78rem;
      color: #475569;
    }

    /* ─── WHATSAPP ─── */
    .whatsapp-btn {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 9999;
      background: #25D366;
      color: #fff;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.2rem;
      border-radius: 50px;
      font-weight: 700;
      font-size: 0.88rem;
      box-shadow: 0 4px 16px rgba(37,211,102,0.35);
      transition: transform 0.2s, box-shadow 0.2s;
      text-decoration: none;
    }

    .whatsapp-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(37,211,102,0.45);
    }

    .whatsapp-label { display: inline; }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 860px) {
      .hero-bullets { grid-template-columns: 1fr; max-width: 340px; }
      .hero-content { max-width: 100%; }
      .services-grid { grid-template-columns: repeat(2, 1fr); }
      .reviews-grid { grid-template-columns: repeat(2, 1fr); }
      .about-grid { grid-template-columns: 1fr; }
      .contact-grid { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .trust-bar-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-socials { display: none; }
      .nav-quote { display: none; }
      .nav-hamburger { display: flex; }
      .nav-inner { justify-content: space-between; gap: 1rem; }
      .nav-logo img { width: 190px; }

      .form-row { grid-template-columns: 1fr; }

      /* Tighten hero for above-the-fold fit */
      .hero {
        padding: 1.75rem 0 2rem;
        min-height: 0;
      }
      .hero-badge { margin-bottom: 0.7rem; }
      .hero h1 { margin-bottom: 0.6rem; font-size: clamp(1.65rem, 6vw, 2.25rem); }
      .hero-sub { font-size: 0.88rem; line-height: 1.55; margin-bottom: 0.85rem; max-width: 100%; margin-left: 0; margin-right: 0; }
      .hero-bullets { margin-bottom: 0.9rem; gap: 0.4rem 1rem; margin-left: 0; margin-right: 0; max-width: 100%; }
      .review-widgets { margin-bottom: 1rem; justify-content: flex-start; }
      .review-widget { padding: 0.4rem 0.75rem; }
      .hero-ctas { gap: 0.6rem; justify-content: flex-start; }
      .btn-primary, .btn-secondary { padding: 0.72rem 1.3rem; font-size: 0.88rem; }
      .hero-content { text-align: left; margin: 0; }
    }

    @media (max-width: 580px) {
      .nav-logo img { width: 168px; }
      .services-grid { grid-template-columns: 1fr; }
      .reviews-grid { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
    }

    @media (max-width: 480px) {
      .nav-inner { gap: 0.6rem; }
      .nav-logo img { width: 152px; }
      .nav-phone {
        padding: 0.52rem 0.75rem;
        font-size: 0;
        gap: 0;
      }
      .whatsapp-label { display: none; }
      .whatsapp-btn {
        padding: 0;
        width: 52px;
        height: 52px;
        border-radius: 50%;
        justify-content: center;
      }
    }
  </style>
</head>
<body>

<!-- TOP BANNER -->
<div class="top-banner">Available 24/7 · 7 Days a Week</div>

<!-- NAV -->
<nav>
  <div class="container">
    <div class="nav-inner">
      <a href="#" class="nav-logo" aria-label="Teign Plumbing and Heating home">
        <img src="/teign-plumbing-logo.svg" alt="Teign Plumbing &amp; Heating" width="430" height="112" />
      </a>
      <ul class="nav-links">
        <li><a href="#services">Services</a></li>
        <li><a href="#reviews">Reviews</a></li>
        <li><a href="#about">About Us</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
      <div class="nav-socials">
        <!-- Facebook -->
        <span class="nav-social-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
