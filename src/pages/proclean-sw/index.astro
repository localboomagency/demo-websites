---
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ProCleanSW | Professional Cleaning Services in Dawlish</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      color: #374151;
      background: #fff;
      line-height: 1.6;
    }
    a { text-decoration: none; color: inherit; }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* ─── NAV ─── */
    nav {
      background: #fff;
      border-bottom: 1px solid #E2E8F0;
      position: sticky;
      top: 0;
      z-index: 200;
    }
    .nav-inner {
      display: flex;
      align-items: center;
      gap: 2rem;
      height: 68px;
    }
    .nav-logo {
      display: inline-flex;
      align-items: center;
      flex-shrink: 0;
      text-decoration: none;
    }
    .nav-logo-image {
      display: block;
      width: 184px;
      height: auto;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      flex: 1;
    }
    .nav-links a {
      font-size: 0.88rem;
      font-weight: 500;
      color: #4B5563;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: #1A4DC8; }
    .nav-phone {
      background: #D63080;
      color: #fff;
      padding: 0.65rem 1.4rem;
      border-radius: 6px;
      font-weight: 700;
      font-size: 0.88rem;
      white-space: nowrap;
      flex-shrink: 0;
      transition: background 0.2s, transform 0.15s;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }
    .nav-phone:hover { background: #B8256C; transform: translateY(-1px); }
    .nav-quote {
      background: transparent;
      color: #1A4DC8;
      padding: 0.6rem 1.2rem;
      border-radius: 6px;
      font-weight: 700;
      font-size: 0.85rem;
      border: 2px solid #1A4DC8;
      white-space: nowrap;
      flex-shrink: 0;
      transition: background 0.2s, color 0.2s, transform 0.15s;
    }
    .nav-quote:hover { background: #1A4DC8; color: #fff; transform: translateY(-1px); }
    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: 1.5px solid #1A4DC8;
      border-radius: 6px;
      padding: 0.5rem 0.6rem;
      cursor: pointer;
      flex-shrink: 0;
    }
    .nav-hamburger span {
      display: block;
      width: 20px;
      height: 2px;
      background: #1A4DC8;
      border-radius: 2px;
    }

    /* ─── HERO ─── */
    .hero {
      background: #fff;
      position: relative;
      overflow: hidden;
      padding: 2.5rem 0 3rem;
    }
    .hero::before {
      content: '';
      position: absolute;
      width: 700px;
      height: 700px;
      background: radial-gradient(circle, #c5d7f8 0%, transparent 65%);
      top: -220px;
      right: -180px;
      border-radius: 50%;
      pointer-events: none;
    }
    .hero::after {
      content: '';
      position: absolute;
      width: 320px;
      height: 320px;
      background: radial-gradient(circle, #fad5e9 0%, transparent 70%);
      bottom: -80px;
      left: -60px;
      border-radius: 50%;
      pointer-events: none;
    }
    .hero-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: stretch;
      position: relative;
      z-index: 1;
    }
    .hero-content {
      position: relative;
    }
    .hero-image {
      width: 100%;
      min-height: 320px;
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid #D6E2FB;
      box-shadow: 0 20px 60px rgba(13, 27, 61, 0.14);
      background: #EEF3FD;
    }
    .hero-image img {
      display: block;
      width: 100%;
      height: 100%;
      min-height: 320px;
      object-fit: cover;
      object-position: center;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: #EEF3FD;
      color: #1A4DC8;
      font-size: 0.71rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.3rem 0.85rem;
      border-radius: 100px;
      margin-bottom: 1.1rem;
    }
    .hero h1 {
      font-size: clamp(2rem, 4.5vw, 3.25rem);
      font-weight: 900;
      color: #0D1B3D;
      line-height: 1.08;
      letter-spacing: -0.025em;
      margin-bottom: 0.9rem;
    }
    .hero h1 .accent { color: #1A4DC8; }
    .hero-sub {
      font-size: 1.05rem;
      color: #4B5563;
      line-height: 1.65;
      margin-bottom: 1.2rem;
    }
    .review-widget {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      background: #F8FAFF;
      border: 1.5px solid #D6E2FB;
      border-radius: 8px;
      padding: 0.5rem 1rem;
      margin-bottom: 1.2rem;
    }
    .review-stars { color: #FBBC04; font-size: 0.88rem; letter-spacing: -0.5px; }
    .review-text { font-size: 0.82rem; color: #374151; font-weight: 500; }
    .hero-bullets {
      list-style: none;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.55rem 2rem;
      margin: 0 0 1.4rem;
    }
    .hero-bullets li {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      font-size: 0.91rem;
      color: #374151;
      font-weight: 500;
    }
    .bullet-icon {
      width: 20px;
      height: 20px;
      min-width: 20px;
      background: #E7F5EE;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #1CA057;
    }
    .hero-ctas {
      display: flex;
      justify-content: flex-start;
      gap: 0.85rem;
      flex-wrap: wrap;
    }
    .btn-primary {
      background: #D63080;
      color: #fff;
      padding: 0.9rem 1.75rem;
      border-radius: 6px;
      font-weight: 700;
      font-size: 0.95rem;
      transition: background 0.2s, transform 0.15s;
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
    }
    .btn-primary:hover { background: #B8256C; transform: translateY(-2px); }
    .btn-secondary {
      background: transparent;
      color: #0D1B3D;
      padding: 0.9rem 1.75rem;
      border-radius: 6px;
      font-weight: 700;
      font-size: 0.95rem;
      border: 2px solid #CBD5E1;
      transition: border-color 0.2s, transform 0.15s;
      display: inline-block;
    }
    .btn-secondary:hover { border-color: #0D1B3D; transform: translateY(-2px); }

    /* ─── TRUST BAR ─── */
    .trust-bar {
      background: #0D1B3D;
      padding: 1.75rem 0;
    }
    .trust-bar-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      text-align: center;
    }
    .trust-item {
      padding: 0.5rem 1rem;
      border-right: 1px solid rgba(255,255,255,0.1);
    }
    .trust-item:last-child { border-right: none; }
    .trust-number {
      font-size: 1.55rem;
      font-weight: 800;
      color: #fff;
      line-height: 1;
      margin-bottom: 0.3rem;
    }
    .trust-number .accent { color: #D63080; }
    .trust-label {
      font-size: 0.72rem;
      color: rgba(255,255,255,0.5);
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    /* ─── SERVICES ─── */
    .services {
      background: #F8FAFF;
      padding: 5rem 0;
    }
    .section-header {
      text-align: center;
      margin-bottom: 3rem;
    }
    .section-eyebrow {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #1A4DC8;
      margin-bottom: 0.6rem;
    }
    .section-header h2 {
      font-size: clamp(1.5rem, 3vw, 2.1rem);
      font-weight: 800;
      color: #0D1B3D;
      letter-spacing: -0.02em;
      margin-bottom: 0.55rem;
    }
    .section-header p {
      color: #6B7280;
      font-size: 0.95rem;
      max-width: 500px;
      margin: 0 auto;
      line-height: 1.65;
    }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
    .service-card {
      background: #fff;
      border: 1px solid #E2E8F0;
      border-top: 3px solid #1A4DC8;
      border-radius: 10px;
      padding: 1.75rem;
      transition: box-shadow 0.2s, transform 0.2s;
    }
    .service-card:hover {
      box-shadow: 0 6px 24px rgba(26,77,200,0.1);
      transform: translateY(-3px);
    }
    .service-icon {
      width: 44px;
      height: 44px;
      background: #EEF3FD;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #1A4DC8;
      margin-bottom: 1rem;
    }
    .service-card h3 {
      font-size: 1rem;
      font-weight: 700;
      color: #0D1B3D;
      margin-bottom: 0.5rem;
    }
    .service-card p {
      font-size: 0.87rem;
      color: #6B7280;
      line-height: 1.65;
    }

    /* ─── REVIEWS ─── */
    .reviews {
      background: #fff;
      padding: 5rem 0;
    }
    .reviews-meta {
      text-align: center;
      margin-bottom: 2.5rem;
    }
    .reviews-score {
      font-size: 3rem;
      font-weight: 900;
      color: #0D1B3D;
      line-height: 1;
      letter-spacing: -0.04em;
    }
    .reviews-stars {
      color: #FBBC04;
      font-size: 1.4rem;
      margin: 0.3rem 0;
    }
    .reviews-count {
      font-size: 0.88rem;
      color: #6B7280;
      margin-bottom: 1.3rem;
    }
    .reviews-meta h2 {
      font-size: clamp(1.4rem, 2.5vw, 2rem);
      font-weight: 800;
      color: #0D1B3D;
      letter-spacing: -0.02em;
    }
    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
    .review-card {
      background: #F8FAFF;
      border: 1px solid #E2E8F0;
      border-radius: 10px;
      padding: 1.6rem;
    }
    .review-card-stars {
      color: #FBBC04;
      font-size: 0.9rem;
      letter-spacing: -0.5px;
      margin-bottom: 0.85rem;
    }
    .review-quote {
      font-size: 0.88rem;
      color: #374151;
      line-height: 1.7;
      margin-bottom: 1rem;
      font-style: italic;
    }
    .review-author {
      font-size: 0.85rem;
      font-weight: 700;
      color: #0D1B3D;
    }
    .review-location {
      font-size: 0.78rem;
      color: #9CA3AF;
      margin-top: 0.1rem;
    }

    /* ─── ABOUT ─── */
    .about {
      background: #F8FAFF;
      padding: 5rem 0;
    }
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }
    .about-eyebrow {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #1A4DC8;
      margin-bottom: 0.7rem;
    }
    .about-content h2 {
      font-size: clamp(1.4rem, 2.5vw, 2rem);
      font-weight: 800;
      color: #0D1B3D;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-bottom: 1.2rem;
    }
    .about-content p {
      font-size: 0.93rem;
      color: #4B5563;
      line-height: 1.7;
      margin-bottom: 1rem;
    }
    .about-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      margin-top: 1.2rem;
    }
    .about-list li {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      font-size: 0.9rem;
      color: #374151;
      font-weight: 500;
    }
    .about-list-icon {
      width: 20px;
      height: 20px;
      min-width: 20px;
      background: #E7F5EE;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #1CA057;
    }
    .about-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .about-stat {
      background: #fff;
      border: 1px solid #E2E8F0;
      border-radius: 10px;
      padding: 1.4rem;
    }
    .about-stat-number {
      font-size: 1.7rem;
      font-weight: 900;
      color: #1A4DC8;
      line-height: 1;
      letter-spacing: -0.03em;
      margin-bottom: 0.35rem;
    }
    .about-stat-label {
      font-size: 0.78rem;
      color: #6B7280;
      font-weight: 500;
      line-height: 1.35;
    }

    /* ─── CONTACT ─── */
    .contact {
      background: #fff;
      padding: 5rem 0;
    }
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 4rem;
      align-items: start;
    }
    .contact-info h2 {
      font-size: clamp(1.4rem, 2.5vw, 2rem);
      font-weight: 800;
      color: #0D1B3D;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-bottom: 0.8rem;
    }
    .contact-info > p {
      font-size: 0.93rem;
      color: #4B5563;
      line-height: 1.65;
      margin-bottom: 2rem;
    }
    .contact-detail { margin-bottom: 1.1rem; }
    .contact-detail-label {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #9CA3AF;
      margin-bottom: 0.2rem;
    }
    .contact-detail-value {
      font-size: 0.93rem;
      color: #0D1B3D;
      font-weight: 600;
      line-height: 1.5;
    }
    .contact-detail-value a { color: #0D1B3D; }
    .contact-detail-value a:hover { color: #1A4DC8; text-decoration: underline; }
    .contact-form {
      background: #F8FAFF;
      border: 1px solid #E2E8F0;
      border-radius: 12px;
      padding: 2.5rem;
    }
    .contact-form h3 {
      font-size: 1.1rem;
      font-weight: 800;
      color: #0D1B3D;
      margin-bottom: 1.5rem;
    }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .form-group { margin-bottom: 1.2rem; }
    .form-group label {
      display: block;
      font-size: 0.72rem;
      font-weight: 700;
      color: #374151;
      margin-bottom: 0.4rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 0.72rem 1rem;
      border: 1.5px solid #D1D5DB;
      border-radius: 6px;
      font-family: inherit;
      font-size: 0.93rem;
      color: #0D1B3D;
      background: #fff;
      transition: border-color 0.2s;
      outline: none;
      -webkit-appearance: none;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus { border-color: #1A4DC8; }
    .form-group textarea { resize: vertical; min-height: 110px; }
    .form-submit {
      width: 100%;
      background: #D63080;
      color: #fff;
      border: none;
      padding: 0.9rem;
      border-radius: 6px;
      font-family: inherit;
      font-size: 0.97rem;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s;
    }
    .form-submit:hover { background: #B8256C; transform: translateY(-1px); }

    /* ─── FOOTER ─── */
    footer {
      background: #0A1428;
      color: #94A3B8;
      padding: 3.5rem 0 2rem;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: 3rem;
      margin-bottom: 2.5rem;
    }
    .footer-logo {
      display: inline-flex;
      align-items: center;
      margin-bottom: 0.75rem;
    }
    .footer-logo-image {
      display: block;
      width: 168px;
      height: auto;
    }
    .footer-brand-desc {
      font-size: 0.83rem;
      line-height: 1.65;
      color: #64748B;
      margin-bottom: 1.3rem;
    }
    .footer-social {
      display: flex;
      gap: 0.5rem;
    }
    .footer-social-item {
      width: 34px;
      height: 34px;
      border-radius: 6px;
      background: rgba(255,255,255,0.07);
      color: #64748B;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s, color 0.2s;
    }
    .footer-social-item:hover { background: rgba(255,255,255,0.13); color: #94A3B8; }
    .footer-col-title {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.09em;
      color: #fff;
      margin-bottom: 1.1rem;
    }
    .footer-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
    }
    .footer-list li {
      font-size: 0.83rem;
      color: #64748B;
      line-height: 1.5;
    }
    .footer-bottom {
      border-top: 1px solid rgba(255,255,255,0.08);
      padding-top: 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .footer-copy { font-size: 0.78rem; color: #475569; }

    /* ─── WHATSAPP ─── */
    .whatsapp-btn {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 9999;
      background: #25D366;
      color: #fff;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.2rem;
      border-radius: 50px;
      font-weight: 700;
      font-size: 0.88rem;
      box-shadow: 0 4px 16px rgba(37,211,102,0.35);
      transition: transform 0.2s, box-shadow 0.2s;
      text-decoration: none;
    }
    .whatsapp-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(37,211,102,0.45);
    }
    .whatsapp-label { display: inline; }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 860px) {
      .services-grid { grid-template-columns: repeat(2, 1fr); }
      .reviews-grid { grid-template-columns: repeat(2, 1fr); }
      .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .trust-bar-grid { grid-template-columns: repeat(2, 1fr); }
      .trust-item { border-right: none; }
      .hero-inner { grid-template-columns: 1fr; gap: 2.5rem; }
      .hero-image { aspect-ratio: 16 / 7; }
      .hero-image img { min-height: 0; }
    }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-quote { display: none; }
      .nav-inner { height: 60px; }
      .nav-logo { flex: 1; }
      .nav-logo-image { width: 156px; }
      .nav-hamburger { display: flex; }
      .nav-phone { padding: 0.52rem 0.9rem; font-size: 0.82rem; }

      .hero { padding: 2.5rem 0 3rem; }
      .hero::before { width: 380px; height: 380px; top: -100px; right: -100px; }
      .hero::after { display: none; }
      .hero-bullets { grid-template-columns: 1fr; gap: 0.5rem; }
      .btn-primary, .btn-secondary { padding: 0.78rem 1.4rem; font-size: 0.9rem; }
    }

    @media (max-width: 580px) {
      .services-grid { grid-template-columns: 1fr; }
      .reviews-grid { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
    }

    @media (max-width: 480px) {
      .form-row { grid-template-columns: 1fr; }
      .whatsapp-label { display: none; }
      .whatsapp-btn {
        padding: 0;
        width: 52px;
        height: 52px;
        border-radius: 50%;
        justify-content: center;
      }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="container">
    <div class="nav-inner">
      <a href="#" class="nav-logo" aria-label="ProCleanSW home">
        <img src="/proclean-sw-logo.svg" alt="ProCleanSW" class="nav-logo-image" width="386" height="92" />
      </a>
      <ul class="nav-links">
        <li><a href="#services">Services</a></li>
        <li><a href="#reviews">Reviews</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
